<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="CheckDisplayMessage" verbose="1" parallel="tests" thread-count="5">
    <test name="Check Display Message Tests - Enhancedweb">
        <parameter name="theme" value="enhancedweb"/>
        <classes>
            <class name="scripts.CCBillPayment">
                <methods>
                <include name="PGP_17782_ValidateSingleQuotesinRespMsgReplacedWithBlanks"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="Check Display Message Tests - Enhancedwap">
        <parameter name="theme" value="enhancedwap"/>
        <parameter name="mobileEmulation" value="Nexus 5"/>
        <parameter name="userAgent"
                   value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
        <classes>
            <class name="scripts.CCBillPayment">
                <methods>
                    <include name="PGP_17782_ValidateSingleQuotesinRespMsgReplacedWithBlanks"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="Check Display Message Tests - Native">
        <parameter name="isNativePlus" value="false"/>
        <classes>
            <class name="scripts.Native.ProcessTransactionTests">
                <methods>
                    <include name="PGP_17782_ValidateSingleQuotesinRespMsgReplacedWithBlanks"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="Check Display Message Tests - NativePlus">
        <parameter name="isNativePlus" value="true"/>
        <classes>
            <class name="scripts.Native.ProcessTransactionTests">
                <methods>
                    <include name="PGP_17782_ValidateSingleQuotesinRespMsgReplacedWithBlanks"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="Check Display Message Tests - Offline">
        <classes>
            <class name="scripts.api.Offline.OffLineTxn">
                <methods>
                    <include name="PGP_17782_ValidateSingleQuotesinRespMsgReplacedWithBlanks"/>
                </methods>
            </class>
        </classes>
    </test>

</suite>