<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="NativeMDRCustomRate" verbose="1" parallel="methods" thread-count="6">
    <test name="NativeMDRCustomRateisNativePlusfalse">
        <parameter name="isNativePlus" value="false"/>
        <classes>
            <class name="scripts.customFeeRateFactor.MDRMerchant.NativeMDRCustomRate"/>
        </classes>
    </test>

    <test name="NativeMDRCustomRateisNativePlustrue">
        <parameter name="isNativePlus" value="true"/>
        <classes>
            <class name="scripts.customFeeRateFactor.MDRMerchant.NativeMDRCustomRate"/>
        </classes>
    </test>
</suite>
