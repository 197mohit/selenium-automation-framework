<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="NativePCFCustomRate" verbose="1" parallel="methods" thread-count="10">
    <test name="NativePCFCustomRateisNativePlustrue">
        <parameter name="isNativePlus" value="true"/>
        <classes>
            <class name="scripts.customFeeRateFactor.PCFMerchant.NativePCFCustomRate"/>
        </classes>
    </test>
    <test name="NativePCFCustomRateisNativePlusfalse">
        <parameter name="isNativePlus" value="false"/>
        <classes>
            <class name="scripts.customFeeRateFactor.PCFMerchant.NativePCFCustomRate"/>
        </classes>
    </test>
</suite>
