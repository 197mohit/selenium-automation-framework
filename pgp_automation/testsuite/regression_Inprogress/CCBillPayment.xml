<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="CCBillPayment" verbose="1" parallel="tests" thread-count="12">
    <test name="CCBillPayment on EnhancedWeb">
        <parameter name="theme" value="enhancedweb"/>
        <classes>
            <class name="scripts.CCBillPayment">
                <methods>
                    <include name="PGP_464_ccBillPaymentViaNB"/>
                    <include name="PGP_465_ccBillPaymentViaDC"/>
                    <include name="validateCCBillPaymentUsingDC"/>
                    <include name="validateCCBillPaymentUsingSavedCard"/>
                    <include name="validateCCBillPaymentUsingRetryDC"/>
                    <include name="validateCCBillPaymentUsingRetrySavedCard"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="CCBillPayment on EnhancedWap">
        <parameter name="theme" value="enhancedwap"/>
        <parameter name="payMode" value="CC"/>
        <parameter name="mobileEmulation" value="Nexus 5"/>
        <parameter name="userAgent"
                   value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
        <classes>
            <class name="scripts.CCBillPayment">
                <methods>
                    <include name="PGP_464_ccBillPaymentViaNB"/>
                    <include name="PGP_465_ccBillPaymentViaDC"/>
                    <include name="validateCCBillPaymentUsingDC"/>
                    <include name="validateCCBillPaymentUsingSavedCard"/>
                    <include name="validateCCBillPaymentUsingRetryDC"/>
                    <include name="validateCCBillPaymentUsingRetrySavedCard"/>
                </methods>
            </class>
        </classes>
    </test>

    <parameter name="browser" value="chrome"/>
    <test name="Check Display Message Tests - Enhancedweb">
        <parameter name="theme" value="enhancedweb"/>
        <classes>
            <class name="scripts.CCBillPayment">
                <methods>
                    <include name="PGP_17782_ValidateSingleQuotesinRespMsgReplacedWithBlanks"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="Check Display Message Tests - Enhancedwap">
        <parameter name="theme" value="enhancedwap"/>
        <parameter name="mobileEmulation" value="Nexus 5"/>
        <parameter name="userAgent"
                   value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
        <classes>
            <class name="scripts.CCBillPayment">
                <methods>
                    <include name="PGP_17782_ValidateSingleQuotesinRespMsgReplacedWithBlanks"/>
                </methods>
            </class>
        </classes>
    </test>

</suite>