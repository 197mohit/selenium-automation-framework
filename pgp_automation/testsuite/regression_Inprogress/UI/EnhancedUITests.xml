<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="EnhancedUITests" verbose="1" parallel="tests" thread-count="12">
    <test name="Enhanced UI Tests">
        <parameter name="browser" value="chrome"/>
        <parameter name="theme" value="enhancedwap"/>
        <parameter name="mobileEmulation" value="Nexus 5"/>
        <parameter name="userAgent"
                   value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
        <classes>
            <class name="scripts.UI.EnhancedUITests"/>
        </classes>
    </test>

    <test name="Enhanced cases for PGP-21772">
        <classes>
            <class name="scripts.UI.EnhancedUITests">
                <methods>
                    <include name="enhancedOrderingNonLoggedIn"/>
                    <include name="enhancedOrderingLoggedIn"/>
                    <include name="enhancedOrderingLogInCashierPage"/>
                    <include name="enhancedOrderingHybrid"/>
                    <include name="enhancedOrderingHybridSSO"/>
                    <include name="enhancedOrderingAddMoneySSO"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>