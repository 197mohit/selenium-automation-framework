<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="AddNPay" verbose="1" parallel="tests" thread-count="12">
    <test name="AddNPay  with enhancedweb">
        <parameter name="theme" value="enhancedweb"/>
        <classes>
            <class name="scripts.AddNPay">
                <methods>
                    <include name="addnPay_PPI_S_sufficientBal"/>
                    <include name="addnPay_SC_S"/>
                    <include name="addnPay_CC_S"/>
                    <include name="addnPay_DC_S"/>
                    <include name="addnPay_NB_S"/>
                    <include name="addnPay_UPI_S"/>
                    <include name="PGP_114_successfulAddNPayWithWalletPaymentModeInCheckoutPage"/>
                    <include name="addnPay_CC_S_withSSOToken"/>
                    <include name="PPI_S_AddnpayDisabled"/>
                    <include name="addnPay_CC_S_CheckforCardSaved"/>
                    <include name="addnPay_CC_S_ZeroBalance"/>
                    <include name="addnPay_CC_S_loginOnCashier"/>
                    <include name="addnPay_CC_F_3DPageCancel"/>
                    <include name="addnPay_CC_F_ZeroAmount"/>
                    <include name="addnPay_CC_F_NegativeAmt"/>
                    <!--<include name="AddnPay_DC_S_LoginWithDiffUserOnCashierPage"/>--><!--commented as this are still to be automated-->
                    <include name="addnPay_DC_S_VerifyWalletBalance"/>
                    <include name="addnPay_verifyPaymentModeOnCashierPageBeforeLogin"/>
                    <include name="addnPay_DC_S_withoutLogin"/>
                    <include name="addnPay_CC_F_verifyResponsePage"/>
                    <include name="addnPay_CC_P_verifyResponsePage"/>
                    <include name="addnPay_DC_S_verifyTxnStatusList"/>
                    <include name="addnPay_Retry_F_WhenRetryCountBreached"/>
                    <include name="addnPay_Retry_VerifyRetry"/>
                    <!--<include name="VerifySaveCardListOnCashierAfterLogin"/>-->
                    <include name="addnPay_PPBL_S"/>
                    <include name="testPPBLPayModeIsDisabledWhenUserHasInsufficientPPBLBalance"/>
                    <include name="testErrMsgIsDisplayedWhenUserHasInsufficientPPBLBalance"/>
                    <include name="testNextPayModeIsSelectedWhenUserHasInsufficientPPBLBalance"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="AddNPay-enhancedwap">
        <parameter name="theme" value="enhancedwap"/>
        <parameter name="mobileEmulation" value="Nexus 5"/>
        <parameter name="userAgent"
                   value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
        <classes>
            <class name="scripts.AddNPay">
                <methods>
                    <include name="addnPay_PPI_S_sufficientBal"/>
                    <include name="addnPay_SC_S"/>
                    <include name="addnPay_CC_S"/>
                    <include name="addnPay_DC_S"/>
                    <include name="addnPay_NB_S"/>
                    <include name="addnPay_UPI_S"/>
                    <include name="PGP_114_successfulAddNPayWithWalletPaymentModeInCheckoutPage"/>
                    <include name="addnPay_CC_S_withSSOToken"/>
                    <include name="PPI_S_AddnpayDisabled"/>
                    <include name="addnPay_CC_S_CheckforCardSaved"/>
                    <include name="addnPay_CC_S_ZeroBalance"/>
                    <include name="addnPay_CC_S_loginOnCashier"/>
                    <include name="addnPay_CC_F_3DPageCancel"/>
                    <include name="addnPay_CC_F_ZeroAmount"/>
                    <include name="addnPay_CC_F_NegativeAmt"/>
                    <include name="addnPay_DC_S_VerifyWalletBalance"/>
                    <include name="addnPay_verifyPaymentModeOnCashierPageBeforeLogin"/>
                    <include name="addnPay_DC_S_withoutLogin"/>
                    <include name="addnPay_CC_F_verifyResponsePage"/>
                    <include name="addnPay_CC_P_verifyResponsePage"/>
                    <include name="addnPay_DC_S_verifyTxnStatusList"/>
                    <include name="addnPay_Retry_VerifyRetry"/>
                    <include name="addnPay_PPBL_S"/>
                    <include name="testPPBLPayModeIsDisabledWhenUserHasInsufficientPPBLBalance"/>
                    <include name="testErrMsgIsDisplayedWhenUserHasInsufficientPPBLBalance"/>
                    <include name="testNextPayModeIsSelectedWhenUserHasInsufficientPPBLBalance"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="IDBI NB transaction">
        <classes>
            <class name="scripts.AddNPay">
                <methods>
                    <include name="transactionwithIDBINB"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="PGP-21561">
        <classes>
            <class name="scripts.AddNPay">
                <methods>
                    <include name="testTxnAmtInCallbackAndTxnStatusHas2DecimalPrecision"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="Corporate Cards through AddNPay Flow">
        <classes>
            <class name="scripts.AddNPay">
                <methods>
                    <include name="successCorporateAddPayCCBinCorporateMerchant"/>
                    <include name="successCorporateAddPayDCBinCorporateMerchant"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="AddNPay Wallet limit Breach">
        <classes>
            <class name="scripts.AddNPay">
                <methods>
                    <include name="verifyAddNPayWalletLimitBreached"/>
                </methods>
            </class>
        </classes>
    </test>

</suite>