<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="MDRPCF" verbose="1" parallel="methods" thread-count="20">
    <test name="MDRPCF on enhanced wap">
        <parameter name="theme" value="enhancedwap"/>
        <parameter name="mobileEmulation" value="Nexus 5"/>
        <parameter name="userAgent"
                   value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
        <classes>
            <class name="scripts.MDRPCF.MDRPCF">
                <methods>
                    <exclude name="successfulSeamlessTxnWithCC"/>
                    <exclude name="successfulSeamlessTxnWithDC"/>
                    <exclude name="successfulSeamlessTxnWithNB"/>
                    <exclude name="successfulSeamlessTxnWithSeamlessNB"/>
                    <exclude name="successfulSeamlessTxnWithSeamlessNBPPBL"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="MDRPCF on enhanced web">
        <parameter name="theme" value="enhancedweb"/>
        <classes>
            <class name="scripts.MDRPCF.MDRPCF">
                <methods>
                    <exclude name="successfulSeamlessTxnWithCC"/>
                    <exclude name="successfulSeamlessTxnWithDC"/>
                    <exclude name="successfulSeamlessTxnWithNB"/>
                    <exclude name="successfulSeamlessTxnWithSeamlessNB"/>
                    <exclude name="successfulSeamlessTxnWithSeamlessNBPPBL"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="MDRPCF seamless and seamless NB">
        <classes>
            <class name="scripts.MDRPCF.MDRPCF">
                <methods>
                    <include name="successfulSeamlessTxnWithCC"/>
                    <include name="successfulSeamlessTxnWithDC"/>
                    <include name="successfulSeamlessTxnWithNB"/>
                    <include name="successfulSeamlessTxnWithSeamlessNB"/>
                    <include name="successfulSeamlessTxnWithSeamlessNBPPBL"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>