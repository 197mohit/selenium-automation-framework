<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="MDRPCFNative" verbose="1" parallel="methods" thread-count="20">
    <test name="MDRPCF on Native Plus">
        <parameter name="isNativePlus" value="true"/>
        <classes>
            <class name="scripts.MDRPCF.MDRPCFNative"/>
        </classes>
    </test>

    <test name="MDRPCF on Native">
        <parameter name="isNativePlus" value="false"/>
        <classes>
            <class name="scripts.MDRPCF.MDRPCFNative"/>
        </classes>
    </test>
</suite>