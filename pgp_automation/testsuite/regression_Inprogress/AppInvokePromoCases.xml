<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="AppInvokePromoCases" verbose="1" parallel="tests" thread-count="10">
    <test name="temp-PGP-24050 Promo cases for enhancedwap">
        <parameter name="mobileEmulation" value="Nexus 5"/>
        <parameter name="userAgent"
                   value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
        <classes>
            <class name="scripts.AppInvokePromoCases">
                <methods>
                    <include name="PGP_24050_verifyBulkOffersareAppliedwhenPromoNotPassed"/>
                    <include name="PGP_24050_verifyTxnAmountAndpromoOffersListNotVisiblewhenDiscountPromoPassed"/>
                    <include name="PGP_24050_verifyTxnAmountAndpromoOffersListNotVisibleWhenCashbackPromoPassed"/>
                    <include name="PGP_24050_verifyTxnwhenPromoNotAppliedandValidatePromoisTrue"/>
                    <include name="PGP_24050_verifyTxnwhenPromoNotAppliedandValidatePromoisFalse"/>
                    <include name="PGP_24050_verifyTxnwhenPromoNotAppliedandValidatePromoisTrueAddNPay"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="PGP-27157 Bank offers on PWP Not Supported enhancedwap">
        <parameter name="mobileEmulation" value="Nexus 5"/>
        <parameter name="userAgent"
                   value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
        <classes>
            <class name="scripts.AppInvokePromoCases">
                <methods>
                    <include name="PGP_27157_ValidateBankOffersNotVisiblewithPWPMerchantfterLoggingIn"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>