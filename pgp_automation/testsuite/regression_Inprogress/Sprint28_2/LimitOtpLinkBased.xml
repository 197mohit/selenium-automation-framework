<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="LimitOtpLinkBased" verbose="1" parallel="tests" thread-count="10">
    <test name="PGP 16003 - Link Based Limit OTP breach only API">
        <classes>
            <class name="scripts.Sprint28.LimitOtpLinkBased">
                <methods>
                    <include name="verifyBreachNumber"/>
                    <include name="generateOTPLimit"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="PGP 16003 - Link Based Limit OTP breach on enhanced web">
        <parameter name="theme" value="enhancedweb"/>
        <classes>
            <class name="scripts.Sprint28.LimitOtpLinkBased">
                <methods>
                    <include name="verifySuccessTxn"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="PGP 16003 - Link Based Limit OTP breach on enhanced wap">
        <parameter name="theme" value="enhancedwap"/>
        <parameter name="mobileEmulation" value="Nexus 5"/>
        <parameter name="userAgent"
                   value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
        <classes>
            <class name="scripts.Sprint28.LimitOtpLinkBased">
                <methods>
                    <include name="verifySuccessTxn"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>