<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="AddMoneyMP" verbose="1" parallel="tests" thread-count="12">
    <test name="Add Money MP Fee Cases Enhancedweb">
        <classes>
            <class name="scripts.AddMoneyMP">
                <methods>
                    <include name="validateFullKYCWalletCC"/>
                    <include name="validateFullKYCWalletSavedCC"/>
                    <include name="validateMinKYCWalletLimitNotBreached"/>
                    <include name="validateMinKYCWalletLimitBreached"/>
                    <include name="validateNoKYCWalletLimitNotBreached"/>
                    <include name="validateNoKYCWalletLimitBreached"/>
                    <include name="validateFullKYCGV"/>
                    <include name="validateFullKYCGVSavedCC"/>
                    <include name="validateMinKYCLimitNotBreachedGV"/>
                    <include name="validateMinKYCLimitBreachedGV"/>
                    <include name="validateNoKYCGV"/>
                    <include name="validateFullKYCDC"/>
                    <include name="validateMinKycNB"/>
                    <include name="validateNoKYCDC"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="Add Money MP Fee Cases Enhancedwap">
        <parameter name="theme" value="enhancedwap"/>
        <parameter name="mobileEmulation" value="Nexus 5"/>
        <parameter name="userAgent"
                   value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
        <classes>
            <class name="scripts.AddMoneyMP">
                <methods>
                    <include name="validateFullKYCWalletCC"/>
                    <include name="validateFullKYCWalletSavedCC"/>
                    <include name="validateMinKYCWalletLimitNotBreached"/>
                    <include name="validateMinKYCWalletLimitBreached"/>
                    <include name="validateNoKYCWalletLimitNotBreached"/>
                    <include name="validateNoKYCWalletLimitBreached"/>
                    <include name="validateFullKYCGV"/>
                    <include name="validateFullKYCGVSavedCC"/>
                    <include name="validateMinKYCLimitNotBreachedGV"/>
                    <include name="validateMinKYCLimitBreachedGV"/>
                    <include name="validateNoKYCGV"/>
                    <include name="validateFullKYCDC"/>
                    <include name="validateMinKycNB"/>
                    <include name="validateNoKYCDC"/>
                </methods>
            </class>
        </classes>
    </test>


    <test name="AddMoneyMP-enhancedwap">
        <parameter name="browser" value="chrome"/>
        <parameter name="theme" value="enhancedwap"/>
        <parameter name="mobileEmulation" value="Nexus 5"/>
        <parameter name="userAgent"
                   value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
        <classes>
            <class name="scripts.AddMoneyMP">
                <methods>
                    <include name="PGP_378_verifyTxnIsAllowedWhenCorrectMidIsPassed"/>
                    <include name="PGP_381_VerifyFailureWhenBankHasInsufficientFunds"/>
                    <include name="PGP_383_verifySuccessfulTxnUsingCC"/>
                    <include name="PGP_384_validateTxnNotAllowedWhenDuplicateOrderIdIsPassed"/>
                    <include name="PGP_387_verifyOnlyActiveAcquiringsAreShownAsPayModes"/>
                    <include name="PGP_389_verifyTxnSuccessfullyProcessedWhenPaymentViaSavedCard"/>
                    <include name="PGP_390_verifyTxnDetailsShownInResponsePageAreAsExpected"/>
                    <include name="PGP_394_verifySuccessfulTxnWhenPaymentViaNB"/>
                    <include name="PGP_396_verifySuccessfulTxnWhenPaymentViaDC"/>
                    <include name="PGP_395_verifySuccessfulTxnWhenPaymentViaUPI"/>
                    <include name="testPPBLPayModeIsDisabledWhenUserHasInsufficientPPBLBalance"/>
                    <include name="testErrMsgIsDisplayedWhenUserHasInsufficientPPBLBalance"/>
                    <include name="testNextPayModeIsSelectedWhenUserHasInsufficientPPBLBalance"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="Penny Drop for AddMoney">
        <parameter name="browser" value="chrome"/>
        <parameter name="theme" value="merchantLow|ccdc"/>
        <parameter name="mobileEmulation" value="Nexus 5"/>
        <parameter name="userAgent"
                   value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
        <classes>
            <class name="scripts.AddMoneyMP">
                <methods>
                    <include name="checkSavedCardFormerchantLowccdc"/>
                    <include name="checkUserAbleToSaveCC"/>
                    <include name="checkUserAbleToSaveDC"/>
                    <parameter name="theme" value="enhancedwap">
                        <include name="checkSavedCardForOthertheme"/>
                    </parameter>
                </methods>
            </class>
        </classes>
    </test>


    <test name="IDBI NB transaction">
        <classes>
            <class name="scripts.AddMoneyMP">
                <methods>
                    <include name="verifySuccessfulTxnUsingNBIDBI"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="PGP-20306">
        <classes>
            <class name="scripts.AddMoneyMP">
                <methods>
                    <include name="testCardIndexNoIsPresentInOutputWhenCardTokenRequiredIsTrueInOrder"/>
                    <include name="testCardIndexNoIsAbsentInOutputWhenCardTokenRequiredIsFalseInOrder"/>
                    <include name="testCardIndexNoIsAbsentInOutputWhenCardTokenRequiredParamIsNotPassedInOrder"/>
                    <include name="testCardHashIsPresentInOutput"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="PGP-26893 - Transit Wallet">
        <parameter name="theme" value="enhancedweb"/>
        <classes>
            <class name="scripts.AddMoneyMP">
                <methods>
                    <include name="verifyAddMoneySuccess"/>
                    <include name="verifyMaxLimit2000"/>
                    <include name="verifyLimitExact"/>
                </methods>
            </class>
        </classes>
    </test>

</suite>