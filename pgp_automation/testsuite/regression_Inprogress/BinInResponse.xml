<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="BinInResponse" verbose="1" parallel="tests" thread-count="10">
    <test name="Native Plus BinResponse">
        <parameter name="isNativePlus" value="true"/>
        <classes>
            <class name="scripts.BinInResponse">
                <methods>
                    <include name="validatelastfourdigitsbin_tc1"/>
                    <include name="validatelastfourdigitsbin_tc2"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="Native BinResponse">
        <parameter name="isNativePlus" value="false"/>
        <classes>
            <class name="scripts.BinInResponse">
                <methods>
                    <include name="validatelastfourdigitsbin_tc1"/>
                    <include name="validatelastfourdigitsbin_tc2"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="EnhancedWeb BinResponse">
        <parameter name="theme" value="enhancedweb"/>
        <classes>
            <class name="scripts.BinInResponse">
                <methods>
                    <include name="validatelastfourdigitsbin_tc3"/>
                    <include name="validatelastfourdigitsbin_tc4"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="EnhancedWap BinResponse">
        <parameter name="theme" value="enhancedwap"/>
        <parameter name="payMode" value="CC"/>
        <parameter name="mobileEmulation" value="Nexus 5"/>
        <parameter name="userAgent"
                   value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
        <classes>
            <class name="scripts.BinInResponse">
                <methods>
                    <include name="validatelastfourdigitsbin_tc3"/>
                    <include name="validatelastfourdigitsbin_tc4"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>