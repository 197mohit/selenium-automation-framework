                    <include name="PGP_287_AddMoneyTxnUsingNBLessThan2000"/>
                    <include name="PGP_410_VerifyFailureWhenBankHasInsufficientFunds"/>
                    <include name="PGP_411_validateTxnIsAllowedWhenValidSSOTokenIsPassed"/>
                    <include name="PGP_412_validateTxnNotAllowedWhenDuplicateOrderIdIsPassed"/>
                    <include name="PGP_413_validateTxnNotAllowedWhenExpiredSSoTokenIsPassed"/>
                    <include name="PGP_414_validateTxnNotAllowedWhenInvalidChannelIsPassed"/>
                    <include name="PGP_415_verifyOnlyActiveAcquiringsAreShownAsPayModes"/>
                    <include name="PGP_416_VerifyFailureWhenSSOTokenIsNotPassed"/>
                    <include name="PGP_417_verifyTxnSuccessfullyProcessedWhenPaymentViaSavedCard"/>
                    <include name="PGP_418_verifyTxnDetailsShownInResponsePageAreAsExpected"/>
                    <include name="PGP_420_verifySuccessfulTxnWhenPaymentViaDC"/>
                    <include name="PGP_421_verifyTxnIsAllowedWhenCorrectMidIsPassed"/>
                    <include name="PGP_422_VerifyTxnFailureWhenRequestTypeOtherThanAddMoney"/>
                    <include name="PGP_419_verifySuccessfulTxnWhenPaymentViaUPI"/>
                    <include name="PGP_285_AddMoneyFor0Amt"/>
                    <include name="PGP_285_successfulAddMoneyDC"/>
                    <include name="PGP_286_successfulSavedCardAddMoneyCC"/>
