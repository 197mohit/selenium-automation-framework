<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="OrderStatusV2Tests" verbose="1" parallel="tests" thread-count="10">
    <test name="OrderStatusV2 CustId Tests - EnhancedWeb">
        <parameter name="theme" value="enhancedweb"/>
        <classes>
            <class name="scripts.OrderStatusV2Tests">
                <methods>
                    <include name="verifyCustIdReturnedforSuccessTxn"/>
                    <include name="verifyCustIdReturnedforFailureTxn"/>
                    <include name="verifyCustIdReturnedforPendingTxn"/>
                    <include name="verifyCustIdNotReturnedwhenMidNotConfigured"/>
                    <include name="verifyCustIdReturnedforONUSMerchants"/>
                    <include name="verifyCustIdReturnedforOFFUSMerchants"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>