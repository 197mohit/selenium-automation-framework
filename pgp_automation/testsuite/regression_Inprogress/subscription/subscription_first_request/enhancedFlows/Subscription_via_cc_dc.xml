<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Subscription_via_cc_dc" verbose="1" parallel="tests" thread-count="10">
    <test name="Subscription_via_cc_dc on enhanced web">
        <parameter name="theme" value="enhancedweb"/>
        <parameter name="payMode" value="CC"/>
        <classes>
            <class name="scripts.subscription.subscriptionFirstRequest.enhancedFlows.SubscriptionViaCcDc"/>
        </classes>
    </test>

    <test name="Subscription_via_cc_dc on enhanced wap">
        <parameter name="theme" value="enhancedwap"/>
        <parameter name="mobileEmulation" value="Nexus 5"/>
        <parameter name="userAgent"
                   value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
        <parameter name="payMode" value="CC"/>
        <classes>
            <class name="scripts.subscription.subscriptionFirstRequest.enhancedFlows.SubscriptionViaCcDc"/>
        </classes>
    </test>

    <test name="Subscription PNB DC Enhanced">
        <parameter name="theme" value="enhancedweb"/>
        <classes>
            <class name="scripts.subscription.subscriptionFirstRequest.enhancedFlows.SubscriptionViaCcDc">
                <methods>
                    <include name="ValidatePNB_DC_CardNotSupported"/>
                    <include name="ValidatePNB_DC_CardNotSupportedForAddNPay"/>
                    <include name="ValidateSavedPNB_DC_CardNotSupported"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="Verify Subscription Error Message(TxnAmt=MaxAmt=0) for Enhanced">
        <classes>
            <class name="scripts.subscription.subscriptionFirstRequest.enhancedFlows.SubscriptionViaCcDc">
                <methods>
                    <include name="verifyErrorMessageWhenMaxAmtandTxnAmtisZeroTypeVARIABLE"/>
                    <include name="verifyErrorMessageWhenMaxAmtandTxnAmtisZeroTypeFIX"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>

