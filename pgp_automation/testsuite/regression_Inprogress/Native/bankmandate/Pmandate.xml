<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Emandate" verbose="1" parallel="tests" thread-count="10">
    <test name="P-Mandate Subscription tests">
        <parameter name="isNativePlus" value="false"/>
        <classes>
            <class name="scripts.Native.bankmandate.Pmandate"/>
        </classes>
    </test>

    <test name="P-Mandate">
        <classes>
            <class name="scripts.Native.bankmandate.Pmandate">
                <methods>
                    <include name="VerifyBankNameinFPOPMandateForNATIVE_MF_SIP"/>
                    <include name="VerifyBankNameinFPOPMandateForNATIVE_SUBSCRIPTION"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>