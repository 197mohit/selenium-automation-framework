<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="FetchBinDetails" verbose="1" parallel="methods" thread-count="20">
    <test name="PGP-23725-Correct Error Message Tests for different paymodes">
        <classes>
            <class name="scripts.Native.subscription.NativeProcessSubscription">
                <methods>
                    <include name="verifyHDFCDebitCardNotAllowedwithOnlyHDFC_CCEnabledSubscription"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="PGP-21763 Subscription - Native">
        <classes>
            <class name="scripts.Native.subscription.NativeProcessSubscription">
                <methods>
                    <include name="PGP_21763_verifyInvalidFrequencyUnitMessage"/>
                    <include name="PGP_21763_verifyInvalidSubsAmountTypeMessage"/>
                    <include name="PGP_21763_verifyInvalidMaxSubsAmountMessage"/>
                    <include name="PGP_21763_verifyTxnAmountCannotBeGreaterthanMaxSubsAmountMessage"/>
                    <include name="PGP_21763_verifyGraceDaysCannotBeGreaterthanFrequencyMessage"/>
                    <include name="PGP_21763_verifyInvalidPaymodeSelectedMessage"/>
                    <include name="PGP_21763_verifyMaxAmtGreaterThanPermissibleAmtMessage"/>
                    <include name="PGP_21763_verifyInvalidAppInvokeDeviceMessage"/>
                    <include name="PGP_21763_verifyGraceDaysMandatoryMessage"/>
                    <include name="PGP_21763_verifyTxnAmtNotEqualtoMaxAmtMessage"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="PGP-21763 Subscription Renew - Native">
        <classes>
            <class name="scripts.Native.subscription.NativeProcessSubscription">
                <methods>
                    <include name="verifySubsIDLengthValidationFailedMessage"/>
                    <include name="verifyTxnAmountLengthValidationFailedMessage"/>
                    <include name="verifyInvalidSavedCardIDMessage"/>
                </methods>
            </class>
        </classes>
    </test>


    <test name="Native Process Subscription">
        <parameter name="isNativePlus" value="false"/>
        <classes>
            <class name="scripts.Native.subscription.NativeProcessSubscription"/>
        </classes>
    </test>


    <test name="PGP-23881 Subscription with wallet Amount between 0 and 1 - Native">
        <parameter name="isNativePlus" value="false"/>
        <classes>
            <class name="scripts.Native.subscription.NativeProcessSubscription">
                <methods>
                    <include name="VerifyZeroAmtPaymentWithWalletBalanceLessThanOneNativePPIY"/>
                    <include name="VerifyZeroAmtPaymentWithWalletBalanceLessThanOneNativePPIN"/>
                    <include name="VerifyZeroAmtPaymentWithWalletBalanceLessThanOneNativePPIYSubsOnWalletEnabled"/>
                    <include name="VerifyZeroAmtPaymentWithWalletBalanceLessThanOneNativePPINSubsOnWalletEnabled"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="Native Process Subscription PNB DC">
        <parameter name="isNativePlus" value="false"/>
        <classes>
            <class name="scripts.Native.subscription.NativeProcessSubscription">
                <methods>
                    <include name="ValidateSubscriptionPNB_DCNotSupported"/>
                    <include name="ValidateSubscriptionPNB_DCNotSupportedForADDNPAY"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="PGP-27162 Native Plus">
        <parameter name="isNativePlus" value="true"/>
        <classes>
            <class name="scripts.Native.subscription.NativeProcessSubscription">
                <methods>
                    <include name="PGP_27162_verifySubscriptionwhensubscriptionEnableRetryisZero"/>
                    <include name="PGP_27162_verifySubscriptionwhensubscriptionEnableRetryisOne"/>
                    <include name="PGP_27162_verifySubscriptionwhensubscriptionEnableRetryisGreaterThanOne"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="PGP-21763 Subscription - Native">
        <classes>
            <class name="scripts.Native.subscription.NativeProcessSubscription">
                <methods>
                    <include name="PGP_21763_verifyInvalidFrequencyUnitMessage"/>
                    <include name="PGP_21763_verifyInvalidSubsAmountTypeMessage"/>
                    <include name="PGP_21763_verifyInvalidMaxSubsAmountMessage"/>
                    <include name="PGP_21763_verifyTxnAmountCannotBeGreaterthanMaxSubsAmountMessage"/>
                    <include name="PGP_21763_verifyGraceDaysCannotBeGreaterthanFrequencyMessage"/>
                    <include name="PGP_21763_verifyInvalidPaymodeSelectedMessage"/>
                    <include name="PGP_21763_verifyMaxAmtGreaterThanPermissibleAmtMessage"/>
                    <include name="PGP_21763_verifyInvalidAppInvokeDeviceMessage"/>
                    <include name="PGP_21763_verifyGraceDaysMandatoryMessage"/>
                    <include name="PGP_21763_verifyTxnAmtNotEqualtoMaxAmtMessage"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="PGP-21763 Subscription Renew - Native">
        <classes>
            <class name="scripts.Native.subscription.NativeProcessSubscription">
                <methods>
                    <include name="verifySubsIDLengthValidationFailedMessage"/>
                    <include name="verifyTxnAmountLengthValidationFailedMessage"/>
                    <include name="verifyInvalidSavedCardIDMessage"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="Verify Subscription Error Message(TxnAmt=MaxAmt=0) for Native">
        <classes>
            <class name="scripts.Native.subscription.NativeProcessSubscription">
                <methods>
                    <include name="verifyErrorMessageWhenMaxAmtandTxnAmtisZeroTypeVARIABLE"/>
                    <include name="verifyErrorMessageWhenMaxAmtandTxnAmtisZeroTypeFIX"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="PGP-23279 tests">
        <parameter name="theme" value="enhancedwap"/>
        <parameter name="userAgent"
                   value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
        <classes>
            <class name="scripts.Native.subscription.NativeProcessSubscription">
                <methods>
                    <include name="PGP_23279_verifySuccessBankMandateNativeSubscriptionwithhAppInvokeFlowUpfrontAmt"/>
                    <include name="PGP_23279_verifySuccessBankMandateNativeMFSIPwithhAppInvokeFlowUpfrontAmt"/>
                    <include name="PGP_23279_verifySuccessCCSubscriptionwithhAppInvokeFlowUpfrontAmt"/>
                    <include name="PGP_23279_verifySuccessCCSubscriptionwithhAppInvokeFlowZeroAmt"/>
                    <include name="PGP_23279_verifySuccessDCSubscriptionwithhAppInvokeFlowUpfrontAmt"/>
                    <include name="PGP_23279_verifySuccessDCSubscriptionwithhAppInvokeFlowZeroAmt"/>
                    <include name="PGP_23279_verifySuccessPPISubscriptionwithhAppInvokeFlowUpfrontAmt"/>
                    <include name="PGP_23279_verifySuccessPPISubscriptionwithhAppInvokeFlowZeroAmt"/>
                    <include name="PGP_23279_verifySuccessPPBLSubscriptionwithhAppInvokeFlowUpfrontAmt"/>
                    <include name="PGP_23279_verifySuccessPPBLSubscriptionwithhAppInvokeFlowZeroAmt"/>
                    <include name="PGP_23279_verifySuccessUPISubscriptionwithhAppInvokeFlowUpfrontAmt"/>
                    <include name="PGP_23279_verifyFailedCCSubscriptionwithhAppInvokeFlowUpfrontAmt"/>
                    <include name="PGP_23279_verifyPendingCCSubscriptionwithhAppInvokeFlowUpfrontAmt"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="PGP-18282 Native">
        <classes>
            <class name="scripts.Native.subscription.NativeProcessSubscription">
                <methods>
                    <include name="PGP_18282_ValidateStatusAfterLoginNative"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="PGP-27600 Test Cases">
        <classes>
            <class name="scripts.Native.subscription.NativeProcessSubscription">
                <methods>
                    <include name="payChannelNotBlankFPOv2"/>
                    <include name="payChannelNotBlankFPOv2PayModeBlank"/>
                    <include name="payChannelNotBlankFPOv1PPBL"/>
