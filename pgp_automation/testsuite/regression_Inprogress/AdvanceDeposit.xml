<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="AdvanceDeposit" verbose="1" parallel="tests" thread-count="12">
    <test name="Advance Deposit on enhancedwap Theme">
        <parameter name="theme" value="enhancedwap"/>
        <parameter name="mobileEmulation" value="Nexus 5"/>
        <parameter name="userAgent"
                   value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
        <classes>
            <class name="scripts.AdvanceDeposit">
                <methods>
                    <include name="paymentViaAdvanceDeposit"/>
                    <include name="lowBalanceErrorMessageAdvanceDeposit"/>
                    <include name="t1"/>
                    <include name="t2"/>
                    <include name="t3"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="Advance Deposit on enhancedweb Theme">
        <parameter name="theme" value="enhancedweb"/>
        <classes>
            <class name="scripts.AdvanceDeposit">
                <methods>
                    <include name="paymentViaAdvanceDeposit"/>
                    <include name="lowBalanceErrorMessageAdvanceDeposit"/>
                    <include name="t1"/>
                    <include name="t2"/>
                    <include name="t3"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="Advance Deposit on Native plus">
        <parameter name="isNativePlus" value="true"/>
        <classes>
            <class name="scripts.AdvanceDeposit">
                <methods>
                    <include name="paymentViaAdvanceDepositNative"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="Advance Deposit on Native">
        <parameter name="isNativePlus" value="false"/>
        <classes>
            <class name="scripts.AdvanceDeposit">
                <methods>
                    <include name="paymentViaAdvanceDepositNative"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>