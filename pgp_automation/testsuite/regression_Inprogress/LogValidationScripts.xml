<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="LogValidationScripts" verbose="1" parallel="tests" thread-count="10">
    <test name="PGP-27170 Native plus">
        <parameter name="isNativePlus" value="true"/>
        <classes>
            <class name="scripts.LogValidationScripts">
            </class>
        </classes>
    </test>

    <test name="PGP-27170 Native">
        <parameter name="isNativePlus" value="false"/>
        <classes>
            <class name="scripts.LogValidationScripts">
            </class>
        </classes>
    </test>

    <test name="PGP-28959 - Tests">
        <parameter name="theme" value="enhancedweb"/>
        <classes>
            <class name="scripts.LogValidationScripts">
                <methods>
                    <include name="PGP_28959_VerifyPeonSentinLogsCCTxnOFFUS"/>
                    <include name="PGP_28959_VerifyPeonSentinLogsCCTxnONUS"/>
                    <include name="PGP_28959_VerifyPeonSentinLogsDCTxnOFFUS"/>
                    <include name="PGP_28959_VerifyPeonSentinLogsDCTxnONUS"/>
                </methods>
            </class>
        </classes>
