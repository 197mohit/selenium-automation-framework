<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="TopUpExpress" verbose="1" parallel="tests" thread-count="3">
    <test name="TopUpExpress">
        <classes>
            <class name="scripts.TopUpExpress">
                <methods>
                    <include name="PGP_407_successfulTopupXpressCC"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="PGP-20447:verify Response message for Risk amount for TOP UP Express">
        <classes>
            <class name="scripts.TopUpExpress">
                <methods>
                    <include name="verifyResponseMessageForRiskRejectTxnForDC"/>
                    <include name="verifyResponseMessageForRiskRejectTxnForCC"/>
                </methods>
            </class>
        </classes>
    </test>


</suite>