<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="PGP-39260" verbose="1" parallel="tests" thread-count="2">
    <test name="Verify addMoney transaction for CheckoutJS">
        <parameter name="theme" value="checkoutjs_web_revamp"/>
        <classes>
            <class name="scripts.Native.checkoutjs.CheckoutJsTests">
                <methods>
                    <include name="AddMoneyOnJsCheckoutWithDC"/>
                    <include name="AddMoneyOnJsCheckoutWithNB"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="Verify addMoney transaction for CheckoutJSonEnhanced">
        <parameter name="theme" value="checkoutjs_web_revamp"/>
        <classes>
            <class name="scripts.JSCheckout.CheckoutJSonEnhanced">
                <methods>
                    <include name="AddMoneyOnJsCheckoutOnEnhancedWithCC"/>
                    <include name="AddMoneyOnJsCheckoutOnEnhancedWithPPBL"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>