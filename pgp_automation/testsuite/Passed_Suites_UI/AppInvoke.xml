        <parameter name="theme" value="enhancedwap_revamp"/>
        <parameter name="mobileEmulation" value="Nexus 5"/>
        <parameter name="userAgent"
                   value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
        <classes>
            <class name="scripts.UPISubsMandate.EnhanceUPICollectSubs">
                <methods>
                    <include name="TC_003_Enhanced_MF_Subs_FreqIsBlank"/>
                    <include name="TC_003_Enhanced_MF_Subs_FreqUnitYear"/>
                    <include name="TC_001_Enhanced_MF_Subs_FreqUnitDay"/>
                    <include name="TC_006_Enhanced_MF_Subs_FreqUnitSemiAnually"/>
                    <include name="TC_002_Enhanced_MF_Subs_FreqGreaterthan1_PaymodeBlank"/>
                    <include name="TC_001_Enhanced_MF_Subs_EnableRetryGreaterThan2PaymodeBlank"/>
                    <include name="TC_002_Enhanced_MF_Subs_StartDateGraceDayNull"/>
                    <include name="TC_001_Enhanced_MF_Subs_MaxAmountGreaterThan5000PaymodeNull"/>
                    <include name="TC_001_Enhanced_MF_Subs_FixAmountEqualAmountNotPassed"/>
                    <include name="TC_005_Native_MF_Subs_FreqUnitBiMonthly"/>
                    <include name="TC_004_Enhanced_MF_Subs_FreqUnitQuater"/>
                    <include name="TC_002_Enhanced_MF_Subs_FreqUnitMonth"/>
                    <include name="TC_002_Enhanced_MF_Subs_AccountNumTrueAndInvalid"/>
                    <include name="TC_003_Enhanced_MF_Subs_AccountNumTrueAndInValidUnverifiedFalse"/>
                    <include name="TC_007_Enhanced_MF_Subs_FreqUnitOnDemand"/>
                    <include name="TC_002_Enhanced_MF_Subs_VariableAmountEqualOrLessMaxAmount"/>
                </methods>
            </class>
        </classes>
    </test>
