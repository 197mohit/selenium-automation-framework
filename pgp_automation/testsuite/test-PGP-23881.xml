<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Subscription - PGP-23881" verbose="1" parallel="tests" thread-count="6">
<test name="PGP-23881 Subscription with wallet Amount between 0 and 1 - enhancedweb">
    <parameter name="theme" value="enhancedweb"/>
    <classes>
        <class name="scripts.subscription.subscriptionFirstRequest.enhancedFlows.SubscriptionViaPpi">
            <methods>
                <include name="VerifyZeroAmtPaymentWithWalletBalanceLessThanOnePPIN"/>
                <include name="VerifyZeroAmtPaymentWithWalletBalanceLessThanOnePPIY"/>
                <include name="VerifyZeroAmtPaymentWithWalletBalanceLessThanOnePPIYSubsonWalletEnabled"/>
            </methods>
        </class>
    </classes>
</test>

    <test name="PGP-23881 Subscription with wallet Amount between 0 and 1 - enhancedwap">
    <parameter name="theme" value="enhancedwap"/>
    <parameter name="mobileEmulation" value="Nexus 5"/>
    <parameter name="userAgent"
               value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
    <classes>
        <class name="scripts.subscription.subscriptionFirstRequest.enhancedFlows.SubscriptionViaPpi">
            <methods>
                <include name="VerifyZeroAmtPaymentWithWalletBalanceLessThanOnePPIN"/>
                <include name="VerifyZeroAmtPaymentWithWalletBalanceLessThanOnePPIY"/>
                <include name="VerifyZeroAmtPaymentWithWalletBalanceLessThanOnePPIYSubsonWalletEnabled"/>
            </methods>
        </class>
    </classes>
</test>

<test name="PGP-23881 Subscription with wallet Amount between 0 and 1 - Native">
<parameter name="isNativePlus" value="false"/>
<classes>
    <class name="scripts.Native.subscription.NativeProcessSubscription">
        <methods>
            <include name="VerifyZeroAmtPaymentWithWalletBalanceLessThanOneNativePPIY"/>
            <include name="VerifyZeroAmtPaymentWithWalletBalanceLessThanOneNativePPIN"/>
            <include name="VerifyZeroAmtPaymentWithWalletBalanceLessThanOneNativePPIYSubsOnWalletEnabled"/>
            <include name="VerifyZeroAmtPaymentWithWalletBalanceLessThanOneNativePPINSubsOnWalletEnabled"/>
        </methods>
    </class>
</classes>
</test>
</suite>