                    <include name="PGP_421_verifyTxnIsAllowedWhenCorrectMidIsPassed"/>
                    <include name="PGP_422_VerifyTxnFailureWhenRequestTypeOtherThanAddMoney"/>
                    <include name="PGP_419_verifySuccessfulTxnWhenPaymentViaUPI"/>
                </methods>
            </class>
        </classes>
    </test>
