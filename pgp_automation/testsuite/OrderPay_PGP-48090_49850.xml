<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="OrderPay" verbose="1" parallel="methods" thread-count="5">
    <test name="OrderPayApi">
        <classes>
            <class name="scripts.OrderPayApi">
                <methods>
                    <include name="validatePayOrderApiFailureWithNB"/>
                    <include name="validatePayOrderApiFailureWithUpiIntent"/>
                    <include name="validatePayOrderApiSuccessWithNB"/>
                    <include name="validatePayOrderApiSuccessWithUpiIntent"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>