    <test name="NativePeon">
        <parameter name="isNativePlus" value="false"/>
        <classes>
            <class name="scripts.Native.NativePeon">
                <methods>
                    <!--EMI Txn is not supported in Native, Hence Excluded-->
                    <exclude name="hybridTxnUsingEMI"/>
                    <exclude name="retryTxnUsingEMI"/>
                    <!--Hybrid cases are not supprted to pg2 right now -->
                    <exclude name="hybridTxnUsingSavedCard"/>
                    <exclude name="TC_PT_016"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="Native Plus Peon">
        <parameter name="isNativePlus" value="true"/>
        <classes>
            <class name="scripts.Native.NativePeon">
                <methods>
                    <!--EMI are not supported to pg2 right now-->
                    <exclude name="hybridTxnUsingEMI"/>
                    <exclude name="retryTxnUsingEMI"/>
                    <!--Hybrid cases are not supprted to pg2 right now -->
                    <exclude name="hybridTxnUsingSavedCard"/>
                    <exclude name="TC_PT_016"/>
                </methods>
            </class>
        </classes>
    </test>



