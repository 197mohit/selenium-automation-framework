<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Redirection fixes" verbose="1">
    <test name="Performing Redirection fixes with web theme">
        <parameter name="theme" value="enhancedweb_revamp"/>
        <classes>
            <class name="scripts.PGOnly">
                <methods>
                    <include name="verifyResponseForCancelTxnWhenFf4jFlagIsOn"/>
                    <include name="PGP_23164_verifyLastTxnPaymodeNotSelectedwhenDifferentMidUsedNBTxn"/>
                </methods>
            </class>
            <class name="scripts.WalletOnly">
                <methods>
                    <include name="testTxnAmtInCallbackAndTxnStatusHas2DecimalPrecision"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>