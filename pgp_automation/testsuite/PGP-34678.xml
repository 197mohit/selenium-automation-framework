<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="PGP-34678" verbose="1" thread-count="20" parallel="tests">
    <test name="Verify Upi collect Tab on Enhanced web">
        <parameter name="theme" value="enhancedweb_revamp"/>
        <classes>
            <class name="scripts.PGOnly">
                <methods>
                    <include name="VerifyUPICollect_Tab"/>
                    <include name="VerifyUPICollect_Tab_LoggedIn"/>
                    <include name="VerifyUPICollect_Tab_when_PrefDisabled"/>
                    <include name="VerifyUPICollect_Tab_When_PrefDisabled_LoggedIn"/>
                    <include name="VerifyUPICollect_Via_Login"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="Verify Upi collect Tab on CheckoutJS web">
        <parameter name="theme" value="checkoutjs_web_revamp"/>
        <classes>
            <class name="scripts.Native.checkoutjs.CheckoutJsTests">
                <methods>
                    <include name="VerifyUPICollect_Tab"/>
                    <include name="VerifyUPICollect_Tab_when_PrefDisabled"/>
                    <include name="VerifyUPICollect_Tab_loggedIN"/>
                    <include name="VerifyUPICollect_Tab_when_PrefDisabled_LoggedIn"/>
                    <include name="VerifyUPICollect_Via_Login"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>