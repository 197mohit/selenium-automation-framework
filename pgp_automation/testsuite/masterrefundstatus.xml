<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="masterRefundStatus" verbose="1" thread-count="4" parallel="tests">
    <test name="masterRefundStatus for enhancedweb_revamp">
        <parameter name="theme" value="enhancedweb_revamp"/>
        <classes>
            <class name="scripts.RefundAsync">
                <methods>
                    <include name="masterRefundStatus"/>
                    <include name="refundStatus"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="masterRefundStatus for enhancedwap_revamp">
        <parameter name="theme" value="enhancedwap_revamp">
            <parameter name="mobileEmulation" value="Nexus 5">
                <parameter name="userAgent"
                           value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25">
                    <classes>
                        <class name="scripts.RefundAsync">
                            <methods>
                                <include name="masterRefundStatus"/>
                                <include name="refundStatus"/>
                            </methods>
                        </class>
                    </classes>
                </parameter>
            </parameter>
        </parameter>
    </test>

    <test name="masterRefundStatus for Native">
        <parameter name="isNativePlus" value="false"/>
        <classes>
            <class name="scripts.RefundAsync">
                <methods>
                    <include name="refundStatus_01"/>
                    <include name="masterRefundStatus_01"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="masterRefundStatus for NativePlus">
        <parameter name="isNativePlus" value="true"/>
        <classes>
            <class name="scripts.RefundAsync">
                <methods>
                    <include name="refundStatus_01"/>
                    <include name="masterRefundStatus_01"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>