<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="subsfixes" verbose="1">
    <test name="Updated Errors for Subscription Enhanced">
        <parameter name="theme" value="enhancedweb_revamp"/>
        <classes>
            <class name="scripts.subscription.subscriptionFirstRequest.enhancedFlows.SubscriptionViaPpi">
                <methods>
                    <include name="VerifyErrorMsgisshownforUPIotherthanPaytmOrBhim"/>
                    <include name="VerifyErrorMsgisshownforUPInotSupportingSubscription"/>
                    <include name="VerifyErrorMsgisshownforInvalidUPI"/>
                    <include name="testNextPayModeIsSelectedWhenUserHasInsufficientPPBLBalance"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="Updated Errors for PGOnly">
        <parameter name="theme" value="enhancedweb_revamp">
            <classes>
                <class name="scripts.PGOnly">
                    <methods>
                        <include name="testNextPayModeIsSelectedWhenUserHasInsufficientPPBLBalance"/>
                    </methods>
                </class>
            </classes>
        </parameter>
    </test>
    <test name="Updated Errors for AddMoneyMP">
        <parameter name="theme" value="enhancedweb_revamp">
            <classes>
                <class name="scripts.AddMoneyMP">
                    <methods>
                        <include name="testNextPayModeIsSelectedWhenUserHasInsufficientPPBLBalance"/>
                    </methods>
                </class>
            </classes>
        </parameter>
    </test>
</suite>