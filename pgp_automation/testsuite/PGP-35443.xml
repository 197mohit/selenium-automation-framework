<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="FD AS A PAYMODE(PGP-35443)" verbose="1" thread-count="20" parallel="tests">
    <test name="FD as a paymode enhanced cases">
        <parameter name="theme" value="enhancedweb_revamp"/>
        <classes>
            <class name="scripts.PGOnly">
                <methods>
                    <include name="verifying_FD_BalanceIsNotVisible"></include>
                    <include name="verifying_FD_BalanceIsVisible"></include>
                </methods>
        </class>
        </classes>
    </test>
    <test name="FD as a paymode CheckoutJS cases">
        <parameter name="theme" value="checkoutjs_web_revamp"/>
        <classes>
            <class name="scripts.Native.checkoutjs.CheckoutJsTests">
                <methods>
                    <include name="verifying_FD_BalanceIsNotVisible"></include>
                    <include name="verifying_FD_BalanceIsVisible"></include>
                </methods>
            </class>
        </classes>
    </test>
</suite>