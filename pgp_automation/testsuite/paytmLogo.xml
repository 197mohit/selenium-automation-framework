<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="PGP-39748" verbose="1" parallel="tests" thread-count="2">

    <test name="Enhanced web flow">
        <parameter name="theme" value="enhancedweb_revamp"/>
        <classes>
            <class name="scripts.PGOnly">
                <methods>
                    <include name="verifyPaytmLogoisVisible"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="Enhanced wap flow">
        <parameter name="theme" value="enhancedwap_revamp"/>
        <classes>
            <class name="scripts.PGOnly">
                <methods>
                    <include name="verifyPaytmLogoisVisibleInMobile"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="Checkout web flow">
        <parameter name="theme" value="checkoutjs_web_revamp"/>
        <classes>
            <class name="scripts.Native.checkoutjs.CheckoutJsTests">
                <methods>
                    <include name="verifyPaytmLogoisVisible"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="Checkout wap flow">
        <parameter name="theme" value="checkoutjs_wap_revamp"/>
        <classes>
            <class name="scripts.Native.checkoutjs.CheckoutJsTests">
                <methods>
                    <include name="verifyPaytmLogoisVisible"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>