<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="EMISubvention" verbose="1" parallel="methods" thread-count="2">
    <test name="Custom checkout">
        <parameter name="isNativePlus" value="true"/>
        <classes>
            <class name="scripts.api.PromoAndEmiSubvention.CustomCheckoutE2ETxn">
                <methods>
                    <include name="TestE2ESuccessResponseWhenBestbankOfferAppliedforNBTxnNon_Loggedin"/>
                    <include name="TestE2ESuccessResponseWhenDiscountedbankOfferAppliedforUPITxnnon_LoggedIn"/>
                </methods>
           </class>
        </classes>
    </test>
    <test name="Simplified offers">
        <parameter name="isNativePlus"  value="false"/>
        <classes>
            <class name="scripts.SimplifiedUnifiedOffers.SimplifiedUnifiedOffersTest">
                <methods>
                    <include name="TestSuccessTxnSimplifiedUnifiedOfferDCNon_loggedIn"/>
                    <include name="TestSuccessTxnSimplifiedUnifiedOfferCCNon_loggedIn"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>