<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="PGP-34005" verbose="1">
    <test name="PGP-34005 for NativePlus">
        <parameter name="isNativePlus" value="true"/>
        <classes>
            <class name="scripts.Native.NativeMF">
                <methods>
                    <include name="validateChecksum"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="PGP-34005 for Native">
        <parameter name="isNativePlus" value="false"/>
        <classes>
            <class name="scripts.Native.NativeMF">
                <methods>
                    <include name="validateChecksum"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>