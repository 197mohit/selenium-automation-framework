<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="LOGO COLORS(PGP-35391)" verbose="1" thread-count="20" parallel="tests">
    <test name="Verifying PayMode Logo colors for Enhanced Web">
        <parameter name="theme" value="enhancedweb_revamp"/>
        <classes>
            <class name="scripts.PGOnly">
                <methods>
                    <include name="Verifying_PayMode_LOGO_Colors"></include>
                </methods>
            </class>
        </classes>
    </test>

    <test name="Verifying PayMode Logo colors for Checkout JS Web">
        <parameter name="theme" value="checkoutjs_web_revamp"/>
        <classes>
            <class name="scripts.Native.checkoutjs.CheckoutJsTests">
                <methods>
                    <include name="Verifying_PayMode_LOGO_Colors"></include>
                </methods>
            </class>
        </classes>
    </test>
</suite>