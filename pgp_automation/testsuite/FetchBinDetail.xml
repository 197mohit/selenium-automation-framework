                    <include name="testFetchBinDetail"/>
                </methods>
            </class>
            <class name="scripts.api.theia.OfflineCompatibilityTest">
                <methods>
                    <include name="testFetchBinDetail"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>