<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Regression test cases for merchant 4 and enhancedwap and enhancedweb themes" verbose="1" thread-count="20"
       parallel="tests">
    <test name="Autologin_enhancedweb">
        <parameter name="theme" value="enhancedweb"/>
        <classes>
            <class name="scripts.Autologin.AutoLogin">
                <methods>
                    <include name="autologin_validateCookie"/>
                    <include name="autologin_validateCookieDeletedAfterLogin"/>
                    <include name="autologin_validateUserLoggedInAfterTxn"/>
                    <include name="autologin_PPBL_S"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="Autologin_enhancedwap">
        <parameter name="theme" value="enhancedwap"/>
        <parameter name="mobileEmulation" value="Nexus 5"/>
        <parameter name="userAgent"
                   value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
        <classes>
            <class name="scripts.Autologin.AutoLogin">
                <methods>
                    <include name="autologin_validateCookie"/>
                    <include name="autologin_validateUserLoggedInAfterTxn"/>
                    <include name="autologin_PPBL_S"/>
                    <exclude name="autologin_validateCookieDeletedAfterLogin"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>