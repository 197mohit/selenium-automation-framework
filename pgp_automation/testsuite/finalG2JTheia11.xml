            <class name="scripts.api.theia.applyPromo.TxnTokenApplyPromoV1Test"/>
            <class name="scripts.api.theia.applyPromo.TxnTokenApplyPromoV2Test">
                <methods>
                    <!-- Exclude Zero Pass Percentage TCs -->
                    <exclude name="test tncUrl when FF4J applyPromoSendResponseTncUrl flag is enabled on mid"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="PGP-24062" >
        <classes>
            <class name="scripts.api.theia.FastForwardTest">
                <methods>
                    <!-- Exclude Zero Pass Percentage TCs -->
                    <exclude name="testSuccess"/>
                </methods>
            </class>
            <class name="scripts.api.theia.fetchBinDetail.SSOTokenFetchBinDetailV1Test">
                <methods>
                    <!-- Exclude Zero Pass Percentage TCs -->
                    <exclude name="fetch BIN when CC_EMI is enabled"/>
                    <exclude name="fetch BIN when DC_EMI is enabled"/>
                    <exclude name="testForBajajfnBinWhenSupported"/>
                    <exclude name="testForPayModeEMIWhenSupported"/>
                </methods>
            </class>
            <class name="scripts.api.theia.fetchBalance.SSOTokenFetchBalanceInfoV1Test">
                <methods>
                    <!-- Exclude Zero Pass Percentage TCs -->
                    <exclude name="test when body mid = null"/>
                    <exclude name="test when body mid equals random value"/>
                    <exclude name="test when body mid is not provided"/>
                    <exclude name="test when body paymentMode equals PAYTM_DIGITAL_CREDIT given merchant and user both do not have PAYTM_DIGITAL_CREDIT configured"/>
                    <exclude name="test when body paymentMode equals PAYTM_DIGITAL_CREDIT given merchant has PAYTM_DIGITAL_CREDIT configured but user does not"/>
                    <exclude name="test when body paymentMode equals PAYTM_DIGITAL_CREDIT given user has PAYTM_DIGITAL_CREDIT configured but merchant does not"/>
                </methods>
            </class>
            <class name="scripts.api.theia.fetchEmiDetail.SSOTokenFetchEmiDetailV1Test"/>
            <class name="scripts.api.theia.fetchEmiDetail.TxnTokenFetchEmiDetailV1Test"/>
            <class name="scripts.api.theia.fetchNbPaymentChannels.SSOTokenFetchNBPaymentChannelsV1Test"/>
            <class name="scripts.api.theia.fetchNbPaymentChannels.TxnTokenFetchNBPaymentChannelsV1Test"/>
            <class name="scripts.api.theia.fetchMerchantInfo.TxnTokenFetchMerchantInfoV1Test"/>
            <class name="scripts.api.theia.fetchMerchantInfo.TxnTokenFetchMerchantInfoV2Test"/>
        </classes>
    </test>

