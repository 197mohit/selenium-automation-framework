<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="postConv" verbose="1">
       <test name="post convinence with enhanced WAP Theme" parallel="methods" thread-count="2">
           <parameter name="theme" value="enhancedwap"/>
           <parameter name="mobileEmulation" value="Nexus 5"/>
           <parameter name="userAgent"
                      value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
           <classes>
               <class name="scripts.PostCovEnhance">
               </class>
           </classes>
       </test>
       <test name="post convinence with enhanced WEB Theme" parallel="methods" thread-count="2">
           <parameter name="theme" value="enhancedweb"/>
           <classes>
               <class name="scripts.PostCovEnhance">
                   <methods>
                       <exclude name="success_PCF_CC_Refund"></exclude>
                       <exclude name="success_PCF_CC_Refund_Partial"></exclude>
                       <exclude name="Failed_PCF_CC_Refund_Partial"></exclude>
                   </methods>
               </class>
           </classes>
       </test>
    <test name="post convinence Native APIs" parallel="methods" thread-count="10">
        <classes>
            <class name="scripts.Native.PCFNative">
            </class>
        </classes>
    </test>
    <test name="Fetch bin details" parallel="methods" thread-count="10">
        <classes>
            <class name="scripts.Native.FetchBinDetails">
                <methods>
                    <include name="FBD_PCF_DC"></include>
                    <include name="FBD_PCF_CC"></include>
                    <include name="FBD_PCF_AMEX"></include>
                </methods>
            </class>
        </classes>
    </test>
</suite>





