<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Redirection fixes" verbose="1">
    <test name="Performing Redirection fixes with web theme">
        <parameter name="theme" value="enhancedweb_revamp"/>
        <classes>
            <class name="scripts.PayViaNotification">
                <methods>
                    <include name="payViaNotification_05"/>
                </methods>
            </class>
            <class name="scripts.Native.merchantLimitMigration">
                <methods>
                    <include name="PGP_5_weeklylimitenhanced"/>
                </methods>
            </class>
            <class name="scripts.UI.PaytmLoginStrip">
                <methods>
                    <include name="loginStripDisableWhenPropLoginStripisNonRetry"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>