<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Redirection fixes" verbose="1">
    <test name="Performing Redirection fixes with web theme">
        <parameter name="theme" value="enhancedweb_revamp"/>
        <classes>
            <class name="scripts.PostCovEnhance">
                <methods>
                    <include name="testChargeAmountPropertyNotDisplayedInMerchantCallbackWhenNotEnabledOnMerchant"/>
                </methods>
            </class>
            <class name="scripts.PGOnly">
                <methods>
                    <include name="PGP_175_cardNotInBinCheckTxnAllowed"/>
                    <include name="PGP_239_successfulPGOnlyDC"/>
                    <include name="PGP_261_successfulPGOnlyDCTxnWhenUserLoggedIn"/>
                    <include name="PGP_28964_verifyCashierPageWhenDataIsEncodedByUImicroservice"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>