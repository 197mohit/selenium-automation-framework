<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="UPIMandateSubscription" verbose="1" thread-count="10" parallel="methods">
    <test name="UPICollectNativeSubs">
        <parameter name="isNativePlus" value="true"/>
        <classes>
            <class name="scripts.UPISubsMandate.UPICollectNativeSubs"/>
        </classes>
    </test>
    <test name="UPIIntentNativeSubs">
        <parameter name="isNativePlus" value="true"/>
        <classes>
            <class name="scripts.UPISubsMandate.UPIIntentNativeSubs"/>
        </classes>
    </test>
    <test name="UPIRenewSubs">
        <parameter name="isNativePlus" value="true"/>
        <classes>
            <class name="scripts.UPISubsMandate.UPIRenewSubs"/>
        </classes>
    </test>
    <test name="UPIEnhanceEnhanceWap">
        <parameter name="theme" value="enhancedwap"/>
        <parameter name="mobileEmulation" value="Nexus 5"/>
        <parameter name="userAgent"
                   value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
        <classes>
            <class name="scripts.UPISubsMandate.EnhanceUPICollectSubs"/>
        </classes>
    </test>

    <test name="UPIEnhanceEnhanceWeb">
        <parameter name="theme" value="enhancedweb"/>
             <classes>
            <class name="scripts.UPISubsMandate.EnhanceUPICollectSubs"/>
        </classes>
    </test>
</suite>
