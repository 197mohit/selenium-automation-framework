<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="merchant-status" verbose="1" parallel="tests" thread-count="4">
    <test name="PGP-42086 for AppInvoke Flow">
        <parameter name="theme" value="enhancedwap_revamp"/>
        <parameter name="mobileEmulation" value="Nexus 5"/>
        <parameter name="userAgent" value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
        <classes>
            <class name="scripts.merchantStatus.AppInvokeMerchantStatusTests">
                <methods>
                    <include name="txnStatus_03"/>
                    <include name="txnStatusInit_03"/>
                    <include name="txnStatusClosed_03"/>
                    <include name="txnStatusInvalid_03"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="PGP-42086 for Offline Flow">
        <classes>
            <class name="scripts.merchantStatus.OfflineMerchantStatusTests">
                <methods>
                    <include name="txnStatus_03"/>
                    <include name="txnStatusInit_03"/>
                    <include name="txnStatusInvalid_03"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>