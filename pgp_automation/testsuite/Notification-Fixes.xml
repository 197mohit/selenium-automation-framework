<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Subscription Fixes">
    <test name="New param addition in peon">
        <parameter name="theme" value="enhancedweb_revamp"/>
        <classes>
            <class name="scripts.PeonTxn">
                <methods>
                    <include name="PGP_37891_DetailingOutErrorResCodeNotConfig"></include>
                    <include name="PGP_398_PeonPGonlyFail"></include>
                    <include name="PGP_397_PeonPGonlyPass"></include>
                    <include name="PGP_399_PeonWalletOnlyPass"></include>
                    <include name="PGP_401_PeonHybridPass"></include>
                </methods>
            </class>
        </classes>
    </test>
    <test name="New param addition in peon for WAP">
        <parameter name="theme" value="enhancedwap_revamp"/>
        <parameter name="mobileEmulation" value="Nexus 5"/>
        <parameter name="userAgent" value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
        <classes>
            <class name="scripts.PeonTxn">
                <methods>
                    <include name="PGP_37891_DetailingOutErrorResCodeNotConfig"></include>
                    <include name="PGP_398_PeonPGonlyFail"></include>
                    <include name="PGP_397_PeonPGonlyPass"></include>
                    <include name="PGP_399_PeonWalletOnlyPass"></include>
                    <include name="PGP_401_PeonHybridPass"></include>
                </methods>
            </class>
        </classes>
    </test>
</suite>