<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="CheckoutJS_ResellerThemeStyle TestSuite" verbose="1" parallel="tests" thread-count="6">
    <test name="CheckoutJS WEB Reseller theme style handling cases">
        <parameter name="theme" value="checkoutjs_web"/>
        <classes>
            <class name="scripts.Native.checkoutjs.CheckoutJsTests">
                <methods>
                    <include name="ValidateChildMIDThemeOverwriteEnabled"/>
                    <include name="ValidateParentMIDThemeOverwriteEnabled"/>
                    <include name="ValidateParentAndChildMIDThemeOverwriteEnabled"/>
                    <include name="ValidateConfigWithParentMIDThemeOverwriteEnabled"/>
                    <include name="ValidateConfigWithChildMIDThemeOverwriteEnabled"/>
                    <include name="ValidateConfigWithParentAndChildThemeOverwriteEnabled"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="CheckoutJS WAP Reseller theme style handling cases">
        <parameter name="theme" value="checkoutjs_wap"/>
        <parameter name="mobileEmulation" value="Nexus 5"/>
        <parameter name="userAgent"
                   value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
        <classes>
            <class name="scripts.Native.checkoutjs.CheckoutJsTests">
                <methods>
                    <include name="ValidateChildMIDThemeOverwriteEnabled"/>
                    <include name="ValidateParentMIDThemeOverwriteEnabled"/>
                    <include name="ValidateParentAndChildMIDThemeOverwriteEnabled"/>
                    <include name="ValidateConfigWithParentMIDThemeOverwriteEnabled"/>
                    <include name="ValidateConfigWithChildMIDThemeOverwriteEnabled"/>
                    <include name="ValidateConfigWithParentAndChildThemeOverwriteEnabled"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="CheckoutJS UI-Revamp Reseller theme style handling cases">
        <parameter name="theme" value="checkoutjs_web_revamp"/>
        <classes>
            <class name="scripts.Native.checkoutjs.CheckoutJsTests">
                <methods>
                    <include name="ValidateChildMIDThemeOverwriteEnabled"/>
                    <include name="ValidateParentMIDThemeOverwriteEnabled"/>
                    <include name="ValidateParentAndChildMIDThemeOverwriteEnabled"/>
                    <include name="ValidateConfigWithParentMIDThemeOverwriteEnabled"/>
                    <include name="ValidateConfigWithChildMIDThemeOverwriteEnabled"/>
                    <include name="ValidateConfigWithParentAndChildThemeOverwriteEnabled"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="CheckoutJS WAP revamp Reseller theme style handling cases">
        <parameter name="theme" value="checkoutjs_wap_revamp"/>
        <parameter name="mobileEmulation" value="Nexus 5"/>
        <parameter name="userAgent"
                   value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
        <classes>
            <class name="scripts.Native.checkoutjs.CheckoutJsTests">
                <methods>
                    <include name="ValidateChildMIDThemeOverwriteEnabled"/>
                    <include name="ValidateParentMIDThemeOverwriteEnabled"/>
                    <include name="ValidateParentAndChildMIDThemeOverwriteEnabled"/>
                    <include name="ValidateConfigWithParentMIDThemeOverwriteEnabled"/>
                    <include name="ValidateConfigWithChildMIDThemeOverwriteEnabled"/>
                    <include name="ValidateConfigWithParentAndChildThemeOverwriteEnabled"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>