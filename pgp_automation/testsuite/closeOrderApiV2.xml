                    <include name="closeOrderSSoAddMoneyFailure"/>
                    <include name="closeOrderChecksumAddMoneyFailure"/>
                    <include name="closeOrderSSoAddMoneyPending"/>
                    <include name="closeOrderChecksumAddMoneyPending"/>
