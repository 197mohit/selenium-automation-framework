<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Redirection fixes" verbose="1">
    <test name="Performing Redirection fixes with web theme">
        <parameter name="theme" value="enhancedweb_revamp"/>
        <classes>
            <class name="scripts.PostCovEnhance">
                <methods>
                    <include name="testNotGettingChargeBackAmtInMerchantStatusAPIWhenRequiredPrefIsDisabled"/>
                    <include name="verify_PCF_CCFee_AfterAmexFee"/>
                </methods>
            </class>
            <class name="scripts.PGOnly">
                <methods>
                    <include name="verifyItemBasedEMI_EmiInfoAndEMiSubvention_Object"/>
                    <include name="verifyAmountBasedEMI_EmiInfoAndEMiSubvention_Object"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="Performing Redirection fixes with wap theme">
        <parameter name="theme" value="enhancedwap_revamp"/>
        <classes>
            <class name="scripts.PostCovEnhance">
                <methods>
                    <include name="testNotGettingChargeBackAmtInMerchantStatusAPIWhenRequiredPrefIsDisabled"/>
                    <include name="verify_PCF_CCFee_AfterAmexFee"/>
                </methods>
            </class>
            <class name="scripts.PGOnly">
                <methods>
                    <include name="PGP_35341_validate_peon_url_in_theia_facade"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>