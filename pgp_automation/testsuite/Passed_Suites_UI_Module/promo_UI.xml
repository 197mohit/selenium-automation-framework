<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Promo_Suite_UI" verbose="1" thread-count="10" parallel="tests">
     <test name="Promo Fixes">
        <parameter name="theme" value="enhancedweb_revamp"/>
        <classes>
            <class name="scripts.Native.FetchPromoCodeDetails">
                <methods>
                    <include name="ValidateMerchantRetryNotAllowedUsingAnyAvailablePromoInNewFlow"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name=" Promo txns - AppInvoke">
        <parameter name="theme" value="enhancedwap_revamp"/>
        <parameter name="mobileEmulation" value="Nexus 5"/>
        <parameter name="userAgent"
                   value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
        <classes>
            <class name="scripts.AppInvokePromoCases">
                <methods>
                    <include name="PGP_27602_verifyTxnProceedswithoutPromoWhenValidatePromoisFalseAddNPay"/>
                    <include name="SuccessfulTransactionWithCashbackWhenValidatePromoIsFalse"/>
                    <include name="SuccessfulTransactionWithCashbackWhenValidatePromoIsTrue"/>
                    <include name="PGP_24050_verifyTxnwhenPromoNotAppliedandValidatePromoisTrueAddNPay"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="PGP-43122">
        <parameter name="theme" value="checkoutjs_web_revamp"/>
        <classes>
            <class name="scripts.Promo.ANDFlow.ModificationInAndOffer"/>
        </classes>
    </test>
</suite>


