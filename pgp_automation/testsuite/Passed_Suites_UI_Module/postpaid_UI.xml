    <test name="POSTPAID ACCOUNT STATUS MSG">
        <parameter name="theme" value="checkoutjs_web_revamp"/>
        <classes>
            <class name="scripts.PaytmDigitalCard">
                <methods>
                    <include name="postpaidMessage_expiredAccount"/>
