<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="secondary regression" verbose="1" parallel="methods" thread-count="7">
    <test name="Promo OR Flow">
        <classes>
            <class name="scripts.or.FetchCardDetailsAPI"/>
        </classes>
    </test>
    <test name="Promo And Flow">
        <classes>
            <class name="scripts.api.theia.FetchAllPaymentOffers"/>
            <class name="scripts.api.theia.ProcessTransactionAPI"/>
        </classes>
    </test>
    <test name="Payments API's">
        <classes>
            <class name="scripts.api.theia.InitiateTransaction"/>
            <class name="scripts.api.theia.FetchQRPaymentDetailsAPITest"/>
            <class name="scripts.api.theia.FetchCardIndexNumber"/>
            <class name="scripts.api.theia.FetchNBPaymentChannels"/>
        </classes>
    </test>
    <test name="Instant Refund">
        <classes>
            <class name="scripts.api.instantrefund.AsyncRefund"/>
            <class name="scripts.api.instantrefund.RefundAccountAdd"/>
            <class name="scripts.api.instantrefund.RefundAccountQuery"/>
            <class name="scripts.api.instantrefund.RefundAccountRemove"/>
            <class name="scripts.api.instantrefund.RefundAccountValidate"/>
            <class name="scripts.api.instantrefund.RefundConsultView"/>
        </classes>
    </test>
    <test name="Session Compatibility">
        <classes>
            <class name="scripts.api.theia.CompatibilityTest"/>
            <class name="scripts.api.theia.OfflineCompatibilityTest"/>
        </classes>
    </test>
</suite>