<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="ThematicUI_Suite" verbose="1" parallel="methods" thread-count="2">
    <test name="Thematic UI Test cases enhancedweb">
        <parameter name="theme" value="enhancedweb"/>
        <classes>
            <class name="scripts.ThematicTests">
                <methods>
                    <include name="t1"/>
                    <include name="t3"/>
                    <include name="t4"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="Thematic UI Test cases enhancedwap">
        <classes>
            <class name="scripts.ThematicTests">
                <methods>
                    <parameter name="mobileEmulation" value="Nexus 5"/>
                    <parameter name="userAgent"
                               value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
                    <parameter name="theme" value="enhancedwap"/>
                    <include name="t3"/>
                    <include name="t2"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>