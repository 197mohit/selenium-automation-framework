            <class name="scripts.Sprint28.AutoRefund">
                <methods>
                    <include name="PGP_verifyResponseWithAmountGraterThanLimitAmount"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="Refund Async with enhancedweb">
        <parameter name="theme" value="enhancedweb_revamp"/>
