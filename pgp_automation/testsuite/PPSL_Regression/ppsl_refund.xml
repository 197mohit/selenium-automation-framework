<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Refund_Suite" verbose="1" thread-count="15" parallel="tests">
    <test name="Refund status V1 - enhancedwap + Refund Refactoring Async/Sync">
        <parameter name="mobileEmulation" value="Nexus 5"/>
        <parameter name="theme" value="enhancedwap_revamp"/>
        <parameter name="userAgent" value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
        <classes>
            <class name="scripts.RefundStatusV1">
                <methods>
                    <include name="successfulPGOnlyDCRefund_asyncStatus"/>
                    <include name="refundDCWithJWTSyncRefund"/>
                    <include name="successfulWalletOnlyRefund_asyncStatus"/>
                    <include name="refundDCWithJWTAsyncRefundDisableFalse"/>
                    <include name="refundPPIWithJWTSyncRefund"/>
                    <include name="refundDCWithJWTAsyncRefund"/>
                    <include name="refundPPBLWithJWTAsyncRefundDisabledFalse"/>
                    <include name="refundPPIWithJWTAsyncRefund"/>
                    <include name="refundPPBLWithJWTAsyncRefundDisabledTrue"/>
                    <include name="refundPPIWithJWTAsyncRefundDisabledFalse"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="temp-PGP-19819 Khata | Callback to Khata system when Khata order payments are refunded for ledger reconciliation">
        <parameter name="isNativePlus" value="false"/>
        <classes>
            <class name="scripts.Native.Khata.KhataRefund">
                <methods>
                    <include name="peonNotSentToMerchant"/>
                    <include name="peonNotSentToMerchant1"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="PGP-14676 Auto Refund on enhanced web">
