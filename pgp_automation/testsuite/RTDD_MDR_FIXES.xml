<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="RTDD Suite" verbose="1" thread-count="20" parallel="tests">
    <test name="MDRMerchant TCs for Native Flow">
        <classes>
            <class name="scripts.customFeeRateFactor.MDRMerchant.DeferredMDRCustomRate">
                <methods>
                    <include name="successfulFeeFactorCCInternationalMoreThan100TxnForMDR"/>
                    <include name="successfulFeeFactorCCInternationalLessThan25TxnForMDR"/>
                </methods>
            </class>
            <class name="scripts.customFeeRateFactor.MDRMerchant.NativeMDRCustomRate">
                <methods>
                    <include name="successfulFeeFactorCCInternationalLessThan100TxnForMDRNative"/>
                    <include name="successfulFeeFactorCCInternationalMoreThan100TxnForMDR"/>
                    <include name="successfulFeeFactorHybridforMDR"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="MDRMerchant TCs for Nativeplus Flow">
        <parameter name="isNativePlus" value="true"/>
        <classes>
            <class name="scripts.customFeeRateFactor.MDRMerchant.DeferredMDRCustomRate">
                <methods>
                    <include name="successfulFeeFactorCCInternationalMoreThan100TxnForMDR"/>
                    <include name="successfulFeeFactorCCInternationalLessThan25TxnForMDR"/>
                </methods>
            </class>
            <class name="scripts.customFeeRateFactor.MDRMerchant.NativeMDRCustomRate">
                <methods>
                    <include name="successfulFeeFactorCCInternationalLessThan100TxnForMDRNative"/>
                    <include name="successfulFeeFactorCCInternationalMoreThan100TxnForMDR"/>
                    <include name="successfulFeeFactorHybridforMDR"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="MDRMerchant TCs for Enhancedweb">
        <parameter name="theme" value="enhancedweb_revamp"/>
        <classes>
            <class name="scripts.customFeeRateFactor.MDRMerchant.EnhancedMDRCustomRate">
                <methods>
                    <include name="successfulFeeFactorCCInternationalLessThan100TxnForMDR"/>
                    <include name="successfulFeeFactorCCInternationalMoreThan25TxnForMDR"/>
                </methods>
            </class>
            <class name="scripts.customFeeRateFactor.MDRMerchant.ScanNPayMDRCustomRate">
                <methods>
                    <include name="successfulFeeFactorCCInternationalMoreThan25TxnForMDRScanNPay"/>
                    <include name="successfulFeeFactorCCInternationalLessThan25TxnForMDRScanNPay"/>
                    <include name="successfulFeeFactorNBForSlabMDRScanNPay"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="MDRMerchant TCs for Enhancedwap">
        <parameter name="theme" value="enhancedwap_revamp"/>
        <parameter name="mobileEmulation" value="Nexus 5"/>
        <parameter name="userAgent" value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
        <classes>
            <class name="scripts.customFeeRateFactor.MDRMerchant.EnhancedMDRCustomRate">
                <methods>
                    <include name="successfulFeeFactorCCInternationalLessThan100TxnForMDR"/>
                    <include name="successfulFeeFactorCCInternationalMoreThan25TxnForMDR"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="MDRMerchant TCs">
        <classes>
            <class name="scripts.customFeeRateFactor.MDRMerchant.OfflineMDRCustomRate">
                <methods>
                    <include name="successfulFeeFactorCCInternationalMoreThan25TxnForMDR"/>
                    <include name="successfulFeeFactorCCInternationalLessThan25TxnForMDR"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>