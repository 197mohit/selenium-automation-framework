<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="temp Subscription" verbose="1" thread-count="10" parallel="tests">

    <test name="PGP-29588 Enhanced subscription testcases for freq fortnight">
        <parameter name="theme" value="enhancedweb_revamp"/>
        <classes>
            <class name="scripts.subscription.subscriptionFirstRequest.defaultFlows.SubscriptionViaPpi">
                <methods>
                    <include name="verifySuccessfulCreateSubscriptionforFreqFortnight"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="Subscription_via_ppi on enhanced web" parallel="methods" thread-count="3">
        <parameter name="theme" value="enhancedweb_revamp"/>
        <classes>
            <class name="scripts.subscription.subscriptionFirstRequest.enhancedFlows.SubscriptionViaWalletOnly">
                <methods>
                    <include name="PGP_21763_verifyInvalidSubsAmountTypeMessage"/>
                    <include name="PGP_21763_verifyInvalidMaxSubsAmountMessage"/>
                    <include name="PGP_21763_verifyInvalidSubsPaymodeMessage"/>
                    <include name="ValidateWalletChecked_walletOnlyMerchantUserLoginatCashierPage"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="Subscription_via_wallet_only on enhanced wap" parallel="methods" thread-count="3">
        <parameter name="theme" value="enhancedwap_revamp"/>
        <parameter name="mobileEmulation" value="Nexus 5"/>
        <parameter name="userAgent"
                   value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
        <parameter name="transactionType" value="PGOnly"/>
        <classes>
            <class name="scripts.subscription.subscriptionFirstRequest.enhancedFlows.SubscriptionViaWalletOnly">
                <methods>
                    <include name="PGP_21763_verifyInvalidSubsAmountTypeMessage"/>
                    <include name="PGP_21763_verifyInvalidMaxSubsAmountMessage"/>
                    <include name="PGP_21763_verifyInvalidSubsPaymodeMessage"/>
                    <include name="ValidateWalletChecked_walletOnlyMerchantUserLoginatCashierPage"/>
                </methods>
            </class>
        </classes>
    </test>

</suite>