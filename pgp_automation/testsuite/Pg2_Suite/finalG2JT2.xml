<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="TheiaOne-2" verbose="1" thread-count="10" parallel="tests">
    <test name="PGP-27186 close order API V2">
        <parameter name="theme" value="enhancedweb_revamp"/>
        <classes>
            <class name="scripts.api.theia.colseOrderv2.CloseOrder">
                <methods>
                    <include name="closeOrderSsoToken"/>
                    <include name="closeOrderTxnToken"/>
                    <include name="closeOrderInvalidSsoToken"/>
                    <include name="closeOrderInvalidTxnToken"/>
                    <include name="closeOrderInvalidOrderidVaildTxnToken"/>
                    <include name="closeOrderInvalidChecksum"/>
                    <include name="closeOrderChecksumToken"/>
                    <include name="closeOrderSsoSuccessNativePlusTxn"/>
                    <include name="closeOrderTxnTokenSuccessNativePlusTxn"/>
                    <include name="closeOrderChecksumSuccessNativePlusTxn"/>
                    <include name="closeOrderSsoSuccessNativeTxn"/>
                    <include name="closeOrderTxnTokenSuccessNativeTxn"/>
                    <include name="closeOrderChecksumSuccessNativeTxn"/>
                    <include name="closeOrderSsoSuccessEnhanceTxn"/>
                    <include name="closeOrderChecksumSuccessEnhanceTxn"/>
                    <include name="closeOrderSsoFailureNativePlusTxn"/>
                    <include name="closeOrderTxnTokenFailureNativePlusTxn"/>
                    <include name="closeOrderChecksumFailureNativePlusTxn"/>
                    <include name="closeOrderSsoFailureNativeTxn"/>
                    <include name="closeOrderTxnTokenFailureNativeTxn"/>
                    <include name="closeOrderChecksumFailureNativeTxn"/>
                    <include name="closeOrderSsoPendingNativePlusTxn"/>
                    <include name="closeOrderTxnTokenPendingNativePlusTxn"/>
                    <include name="closeOrderChecksumPendingNativePlusTxn"/>
                    <include name="closeOrderSsoPendingNativeTxn"/>
                    <include name="closeOrderTxnTokenPendingNativeTxn"/>
                    <include name="closeOrderChecksumPendingNativeTxn"/>
                    <include name="closeOrderSsoPendingEnhanceTxn"/>
                    <include name="closeOrderChecksumPendingEnhanceTxn"/>
                    <include name="closeOrderSsoSuccessOfflineTxn"/>
                    <include name="closeOrderSSoAddMoneySuccess"/>
                    <include name="closeOrderChecksumAddMoneySuccess"/>
                    <include name="closeOrderSSoAddMoneyFailure"/>
                    <include name="closeOrderChecksumAddMoneyFailure"/>
                    <include name="closeOrderSSoAddMoneyPending"/>
                    <include name="closeOrderChecksumAddMoneyPending"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="session-compatibility">
        <classes>
            <class name="scripts.api.theia.CompatibilityTest"/>
            <class name="scripts.api.theia.OfflineCompatibilityTest"/>
            <class name="scripts.PGOnly">
                <parameter name="theme" value="enhancedweb_revamp"/>
                <methods>
                    <parameter name="orderId" value="T1-Retry-theia"/>
                    <include name="PGP_252_verifyPGOnlyTxnWithRetryBackwardCompatibilityCountConfigured"/>
                </methods>
                <!-- Exclude Zero Pass Percentage
                <methods>
                    <parameter name="orderId" value="T2-Retry-theia"/>
                    <include name="PGP_252_verifyPGOnlyTxnWithRetryBackwardCompatibilityCountConfigured"/>
                </methods> -->
            </class>
        </classes>
    </test>
    <test name="session-compatibility_1">
        <classes>
            <class name="scripts.PGOnly">
                <parameter name="theme" value="enhancedweb_revamp"/>
                <methods>
                    <parameter name="orderId" value="T2-theia"/>
                    <include name="PGP_170_successfulPGOnlyBackwardCmpatibilityCC"/>
                </methods>
                <methods>
                    <parameter name="orderId" value="T2-theia"/>
                    <include name="PGP_170_successfulPGOnlyBackwardCmpatibilityCC"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="PGP-15980 Improve order retry success rate on Native">
        <parameter name="isNativePlus" value="false"/>
        <classes>
            <class name="scripts.Sprint28.OrderRetryImproveSuccessRate">
                <methods>
                    <include name="nativeVerifyRetryAllowedForNonRetriableResponseCode"/>
                    <include name="nativeVerifyNoRetryIfCountExhausted"/>
                    <include name="nativeVerifyNoRetryIfCountExhaustedAndRetriableResponse"/>
                    <include name="nativeVerifyNoRetryIfCountisZero"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="PGP-15980 Improve order retry success rate on Native Plus">
        <parameter name="isNativePlus" value="true"/>
        <classes>
            <class name="scripts.Sprint28.OrderRetryImproveSuccessRate">
                <methods>
                    <include name="nativeVerifyRetryAllowedForNonRetriableResponseCode"/>
                    <include name="nativeVerifyNoRetryIfCountExhausted"/>
                    <include name="nativeVerifyNoRetryIfCountExhaustedAndRetriableResponse"/>
                    <include name="nativeVerifyNoRetryIfCountisZero"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="Validate Null pointer exception should not come while initiating txn">
        <parameter name="theme" value="checkoutjs_web_revamp"/>
        <classes>
            <class name="scripts.Native.checkoutjs.CheckoutJsTests">
                <methods>
                    <include name="ValidateTxn_AvoidNullPointerException"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="theia API's 7">
        <classes>
            <class name="scripts.api.theia.FetchPromoCodeDetail"/>
            <class name="scripts.api.theia.FetchPcfDetails"/>
        </classes>
    </test>
    <test name="PGP-26075">
        <classes>
            <class name="scripts.api.theia.fetchPcfDetails.SSOTokenFetchPCFDetailsV1Test"/>
        </classes>
    </test>
    <test name="PGP-30746 FetchBalanceTests">
        <classes>
            <class name="scripts.FetchBalanceTests"/>
        </classes>
    </test>
    <test name="TxnTokenFetchBalanceInfoV1Test">
        <classes>
            <class name="scripts.api.theia.fetchBalance.TxnTokenFetchBalanceInfoV1Test">
                <methods>
                    <!-- Exclude Zero Pass Percentage TCs -->
                    <exclude name="test when body paymentMode equals PAYTM_DIGITAL_CREDIT given merchant and user both do not have PAYTM_DIGITAL_CREDIT configured"/>
                    <exclude name="test when body paymentMode equals PAYTM_DIGITAL_CREDIT given merchant has PAYTM_DIGITAL_CREDIT configured but user does not"/>
                    <exclude name="test when body paymentMode equals PAYTM_DIGITAL_CREDIT given user has PAYTM_DIGITAL_CREDIT configured but merchant does not"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="PGP-24062">
    <classes>
    <class name="scripts.api.theia.fetchBalance.SSOTokenFetchBalanceInfoV1Test">
        <methods>
            <!-- Exclude Zero Pass Percentage TCs -->
            <exclude name="test when body mid = null"/>
            <exclude name="test when body mid equals random value"/>
            <exclude name="test when body mid is not provided"/>
            <exclude name="test when body paymentMode equals PAYTM_DIGITAL_CREDIT given merchant and user both do not have PAYTM_DIGITAL_CREDIT configured"/>
            <exclude name="test when body paymentMode equals PAYTM_DIGITAL_CREDIT given merchant has PAYTM_DIGITAL_CREDIT configured but user does not"/>
            <exclude name="test when body paymentMode equals PAYTM_DIGITAL_CREDIT given user has PAYTM_DIGITAL_CREDIT configured but merchant does not"/>
        </methods>
    </class>
    </classes>
    </test>
</suite>