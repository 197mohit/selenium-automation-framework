    </test>
    <test name="Merchant Updation7">
        <parameter name="isNativePlus" value="false"/>
        <classes>
            <class name="scripts.Native.subscription.NativeProcessSubscription">
                <methods>
                    <include name="payChannelNotBlankFPOv1PayModeBlank"></include>
                    <include name="payChannelNotBlankFPOv1PPBL"></include>
                    <include name="payChannelNotBlankFPOv2"></include>
                    <include name="payChannelNotBlankFPOv2PayModeBlank"></include>
                </methods>
            </class>
        </classes>
    </test>
</suite>