<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Guest Checkout Scripts">
    <test name="Alternate ID txn's via Native+ Flow">
        <parameter name="isNativePlus" value="true"/>
        <classes>
            <class name="scripts.GuestCheckout.GuestCheckoutNative">
                <methods>
                    <include name="verifyfetchBinResponseforAltVISA"></include>
                    <include name="verifyfetchBinResponseforAltRupay"></include>
                    <include name="verifyLPVResponseforAlternateIDVISA"></include>
                    <include name="verifyLPVResponseforAlternateIDRUPAY"></include>
                    <include name="verifySuccessAltIDGenerationforVISA"></include>
                    <include name="verifySuccessTxnforAlternateIDVISA"></include>
                    <include name="verifyRupayCardAltGenCall"></include>
                    <include name="verifyRupayCardAltGenCallOffus"></include>
                    <include name="verifySuccessTxnE2EforAlternateIDVISA"></include>
                    <include name="verifySuccessTxnE2EforAlternateIDVISAOffus"></include>
                </methods>
            </class>
        </classes>
    </test>
