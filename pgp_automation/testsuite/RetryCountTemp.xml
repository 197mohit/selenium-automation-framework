<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="RetryCount_Suite" verbose="1" parallel="tests" thread-count="2">
    <test name="Payment Retry Count Testcases - enhancedweb">
        <parameter name="theme" value="enhancedweb"/>
        <classes>
            <class name="scripts.PGOnly">
                <methods>
                    <include name="ValidatePaymentsRetryCountEqualsFive"/>
                </methods>
            </class>
            <class name="scripts.PayTMExpress">
                <methods>
                    <include name="ValidatePaymentsRetryCountEqualsFive"/>
                </methods>
            </class>
        </classes>
        </test>
    <test name="Payment Retry Count Testcases - native plus">
        <parameter name="isNativePlus" value="true"/>
        <classes>
            <class name="scripts.Native.ProcessTransactionTests">
                <methods>
                <include name="ValidatePaymentsRetryCountEqualsFive"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="Payment Retry Count Testcases - native">
        <parameter name="isNativePlus" value="false"/>
        <classes>
            <class name="scripts.Native.ProcessTransactionTests">
                <methods>
                    <include name="ValidatePaymentsRetryCountEqualsFive"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>