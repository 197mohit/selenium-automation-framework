<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd" >
<suite name="Brand EMI Cases Handling in case of HDFC/SBI Banks" verbose="1">
