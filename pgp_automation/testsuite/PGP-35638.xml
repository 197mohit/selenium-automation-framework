<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="PGP-35638" verbose="1" thread-count="4" parallel="tests">
    <test name="PGP-35638 for enhancedweb_revamp">
        <parameter name="theme" value="enhancedweb_revamp"/>
        <classes>
            <class name="scripts.RefundAsync">
            <methods>
                <include name="closedUPIRefundAsync"/>
                <include name="initUPIRefundAsync"/>
                <include name="closedRefundAsync"/>
                <include name="initRefundAsync"/>
            </methods>
            </class>
        </classes>
    </test>

    <test name="PGP-35638 for enhancedwap_revamp">
        <parameter name="theme" value="enhancedwap_revamp">
            <parameter name="mobileEmulation" value="Nexus 5">
                <parameter name="userAgent"
                           value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25">
                    <classes>
                        <class name="scripts.RefundAsync">
                            <methods>
                                <include name="closedUPIRefundAsync"/>
                                <include name="initUPIRefundAsync"/>
                                <include name="closedRefundAsync"/>
                                <include name="initRefundAsync"/>
                            </methods>
                        </class>
                    </classes>
                </parameter>
            </parameter>
        </parameter>
    </test>

    <test name="PGP-35638 for Native">
        <parameter name="isNativePlus" value="false"/>
        <classes>
            <class name="scripts.RefundAsync">
            <methods>
                <include name="initAsyncRefund"/>
                <include name="closedAsyncRefund"/>
            </methods>
            </class>
        </classes>
    </test>

    <test name="PGP-35638 for NativePlus">
        <parameter name="isNativePlus" value="true"/>
        <classes>
            <class name="scripts.RefundAsync">
                <methods>
                    <include name="initAsyncRefund"/>
                    <include name="closedAsyncRefund"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>