<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Redirection fixes" verbose="1">
    <test name="Performing Redirection fixes with web theme">
        <parameter name="theme" value="enhancedweb_revamp"/>
        <classes>
            <class name="scripts.PGOnly">
                <methods>
                    <include name="refreshPageForLoggedInFlow"/>
                    <include name="PGP_248_DCCancelOn3DPage"/>
                </methods>
            </class>
            <class name="scripts.COD">
                <methods>
                    <include name="COD_verifyllPayModesOnCashier"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>