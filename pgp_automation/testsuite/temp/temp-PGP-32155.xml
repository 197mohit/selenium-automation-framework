<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="PGP-32155 UPI is sent in 'enablePaymentMode' param then All-in-one UPI QR should be displayed" verbose="1">
    <test name="PGP-32155 verifyAllInOneUpiQr">
        <parameter name="theme" value="enhancedweb"/>
        <classes>
            <class name="scripts.PGOnly">
                <methods>
                    <include name="verifyAllInOneUpiQr"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>