<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="PGP-35336" verbose="1">
    <test name="Verify payButton with selected Paymode">
        <parameter name="theme" value="checkoutjs_web_revamp"/>
        <classes>
            <class name="scripts.Native.checkoutjs.CheckoutJsTests">
                <methods>
                    <include name="ValidatePayButtonWithSelectedPaymode"/>
                    <include name="ValidatePayButtonWithSelectedPaymodeAsSC"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="Verify payButton with selected Paymode on enhanced">
        <parameter name="theme" value="enhancedweb_revamp"/>
        <classes>
            <class name="scripts.PGOnly">
                <methods>
                    <include name="ValidatePayButtonWithSelectedPaymode"/>
                    <include name="ValidatePayButtonWithSelectedPaymodeAsSC"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>