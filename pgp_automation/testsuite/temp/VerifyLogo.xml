<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Verify Paytm Logo Theme" verbose="1">
    <test name="Verify Paytm Logo Theme - Web">
        <parameter name="theme" value="checkoutjs_web"/>
        <classes>
            <class name="scripts.Native.checkoutjs.CheckoutJsTests">
                <methods>
                    <include name="verifyLogoColor"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="Verify Paytm Logo Theme - UI Revamp">
        <parameter name="theme" value="checkoutjs_web_revamp"/>
        <classes>
            <class name="scripts.Native.checkoutjs.CheckoutJsTests">
                <methods>
                    <include name="verifyLogoColor"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>