<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="PGP-48963" verbose="1">
    <test name="CheckoutJS cashierPage render based on Wallet paymode ">
        <parameter name="theme" value="checkoutjs_web_revamp"/>
        <classes>
            <class name="scripts.Native.checkoutjs.UISanityCheckoutJS">
                <methods>
                    <include name="ValidateSuccessTxnUsingCCWhenWalletIsNotAvailableOnMID"/>
                    <include name="ValidateSuccessTxnUsingCCWhenWalletIsNotAvailableOnMIDLoggedOut"/>
                    <include name="ValidateWalletWhenWalletAndUPIonMID"/>
                    <include name="ValidateSuccessTxnUsingUPIWhenWalletAndUPIonMID"/>
                    <include name="ValidatWalletByEnteringPhoneNumber"/>
                    <include name="ValidateWalletByEnteringPhoneNumberForWalletOnlyMID"/>
                    <include name="ValidateWalletByEnteringSSOForWalletOnlyMID"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>
