<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="UPI Postpaid Regression Fix" verbose="1" parallel="methods" thread-count="5">
    <test name="UPI Regression Fix">
        <classes>
            <class name="scripts.Native.UpiIntent">
                <methods>
                    <include name="failUpiIntent_staticQR"></include>
                </methods>
            </class>
        </classes>
    </test>
    <test name="Postpaid Regression Fix">
        <parameter name="theme" value="enhancedweb_revamp"/>
        <classes>
            <class name="scripts.AddNPay">
                <methods>
                    <include name="verifyParametersPassesInMetadata"></include>
                </methods>
            </class>
            <class name="scripts.PaytmDigitalCard">
                <methods>
                    <include name="PGP_517_PostPaidAndWalletInactive"></include>
                </methods>
            </class>
        </classes>
    </test>
    <test name="PaytmCC-enhancedwap">
        <parameter name="theme" value="enhancedwap_revamp"/>
        <parameter name="mobileEmulation" value="Nexus 5"/>
        <parameter name="userAgent"
                   value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
        <classes>
            <class name="scripts.PaytmDigitalCard">
                <methods>
                    <include name="PGP_478_Pending"></include>
                </methods>
            </class>
        </classes>
    </test>
</suite>