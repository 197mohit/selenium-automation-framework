<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Bulk provisioning of subvention campaigns for online merchants" verbose="1" thread-count="2" parallel="tests">
    <test name="Validate X_CLIENT in emi subvention requests">
        <parameter name="theme" value="enhancedweb_revamp"/>
        <classes>
            <class name="scripts.EMISubventionTxnTokenFlow">
                <methods>
                    <include name="emiSubClientVerifyItem"/>
                    <include name="emiSubClientVerifyAmount"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>