<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="PGP-23625 Validate Pay using upi apps Paymode" verbose="1" parallel="methods" thread-count="1">
    <test name="PGP-23625 Pay using upi apps Paymode Displayed for enhancedwap">
        <parameter name="theme" value="enhancedwap"/>
        <parameter name="mobileEmulation" value="Nexus 5"/>
        <parameter name="userAgent"
                   value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
        <classes>
            <class name="scripts.PGOnly">
                <methods>
                    <include name="ValidateUPIAppsPaymodeDisplayedwithUPIIntentEnabledMidConfiguredSSOTokenLogin"/>
                    <include name="ValidateUPIAppsPaymodeDisplayedwithUPIIntentEnabledMidConfiguredCashierpageLogin"/>
                    <include name="ValidateUPIAppsPaymodeNotDisplayedWhenUPIIntentNotEnabledMidConfigured"/>
                    <include name="ValidateUPIAppsPaymodeNotDisplayedwithUPIIntentEnabledMidConfiguredSSOTokenLogin"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>