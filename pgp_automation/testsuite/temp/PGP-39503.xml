<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Validating the masked mobile number in Checkout Js and Enhanced flows"  verbose="1">
    <test name="Validating the masked mobile number in Standard checkout JS flows">
        <parameter name="theme" value="enhancedweb_revamp"/>
        <classes>
            <class name="scripts.PGOnly">
                <methods>
                    <include name="verifyMaskedMobileNumberInConsoleAppData"/>
                    <include name="verifyMaskedMobileNumberInSendOTPAPIfromEnhancePage"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="Validating the masked mobile number in Checkout JS flows">
    <parameter name="theme" value="checkoutjs_web_revamp"/>
        <classes>
            <class name="scripts.Native.checkoutjs.CheckoutJsTests">
                <methods>
                    <include name="verifyMaskedMobileNumberInFPOResponse"/>
                    <include name="verifyMaskedMobileNumberInSendOTPAPI"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>