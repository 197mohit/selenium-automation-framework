<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name=" Create UPI Autopay subscription with mandate as irrevocable for selective MCC" verbose="1">
    <test name="Verify revocable status for different MCC Codes in UPI Collect flow">
        <parameter name="theme" value="enhancedweb_revamp"/>
        <classes>
            <class name="scripts.subscription.subscriptionFirstRequest.enhancedFlows.SubscriptionViaCcDc">
                <methods>
                    <include name="PGP_40525_TC01_UPICollectSubs"/>
                    <include name="PGP_40525_TC02_UPICollectSubs"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="Verify revocable status for different MCC Codes in UPI Push flow">
        <classes>
            <class name="scripts.api.UPI.UpiTransactionTests">
                <methods>
                    <include name="PGP_40525_TC_01_validateUpiPushTxnSubs"/>
                    <include name="PGP_40525_TC_02_validateUpiPushTxnSubs"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="Verify revocable status for different MCC Codes in UPI Intent flow">
        <classes>
            <class name="scripts.UPISubsMandate.UPIIntentNativeSubs">
                <methods>
                    <include name="PGP_40525_TC_01_Native_Subs"/>
                    <include name="PGP_40525_TC_02_Native_Subs"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>