<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Checkoutjs UI test cases wap and web UI REVAMP 1" verbose="1">
    <test name="Verify Wap UI Revamp 1 cases">
        <parameter name="theme" value="checkoutjs_wap_revamp"></parameter>
        <classes>
            <class name="scripts.Native.checkoutjs.CheckoutJsTests">
                <methods>
                    <include name="ValidatePCFforNB"/>
                    <include name="ValidateSuccessTxnUsingCCSavedCard"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="Verify Web UI Revamp1 cases">
        <parameter name="theme" value="checkoutjs_web_revamp"></parameter>
        <classes>
            <class name="scripts.Native.checkoutjs.CheckoutJsTests">
                <methods>
                    <include name="ValidatePCFforNB"/>
                    <include name="ValidateSuccessTxnUsingCCSavedCard"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>