            </class>
            <class name="scripts.api.PostPaid.PG2PostPaid">
                <methods>
                    <include name="validateCoThenPaySuccessRentMidOrderModifyPostPaidTxnPG2MID"/>
                    <include name="validateFullTrafficCOPSuccessInternalOrderModifyPostPaidTxnPG2MID"/>
                </methods>
            </class>
            <class name="scripts.api.PPBL.PPBLPG2">
                <methods>
                    <include name="validateFullTrafficYSuccessCOPPPBLInternalOrderModifyTxnPG2MID"/>
                    <include name="validateCoThenPaySuccessRentMidOrderModifyPPBLTxnPG2MID"/>
                </methods>
