                <methods>
                    <include name="validatePG2COPStaticQRUPIPushScanNPay"/>
                    <include name="validatePG2COPUPIPSP"/>
                </methods>
            </class>
            <class name="scripts.api.Wallet.PG2Wallet">
                <methods>
                    <include name="validatePG2COPFullTrafficYSuccessFastForwardTxn"/>
                    <include name="validatePG2COPYSuccessFastForwardTxn"/>
                    <include name="validateFullTrafficYSuccessCOPWalletInternalOrderModifyTxnPG2MID"/>
