<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Bank Transfer TC"  verbose="1">
    <test name="For bank transfer txn , Duplicate txn popup is visible by using same TXN token">
        <parameter name="theme" value="checkoutjs_web_revamp"/>
        <classes>
            <class name="scripts.BankTransferCheckoutTest">
                <methods>
                    <include name="DuplicateTXNPopupvisibleinBankTransfer"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>