<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="temp-PGP-27715 Corporate Card EMI Only" verbose="1" parallel="methods" thread-count="3">
    <test name="PGP-27715 Corporate Card EMI Only Enhancedweb">
        <parameter name="theme" value="enhancedweb"/>
        <classes>
            <class name="scripts.PGOnly">
                <methods>
                    <include name="PGP_27715_validateSuccessTxnUsingEMIOnlyMerchant"/>
                    <include name="PGP_27715_validateSuccessTxnUsingEMI_DC_OnlyMerchantWithoutCorporate"/>
                    <include name="PGP_27715_validateSuccessTxnUsingEMI_DC_OnlyMerchantCorporate"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="PGP-27715 Corporate Card EMI Only Enhancedwap">
        <parameter name="theme" value="enhancedwap"/>
        <parameter name="mobileEmulation" value="Nexus 5"/>
        <parameter name="userAgent"
                   value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>        <classes>
            <class name="scripts.PGOnly">
                <methods>
                    <include name="PGP_27715_validateSuccessTxnUsingEMIOnlyMerchant"/>
                    <include name="PGP_27715_validateSuccessTxnUsingEMI_DC_OnlyMerchantWithoutCorporate"/>
                    <include name="PGP_27715_validateSuccessTxnUsingEMI_DC_OnlyMerchantCorporate"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="PGP-27715 Corporate Card EMI Only Native">
        <parameter name="isNativePlus" value="false">
            <classes>
                <class name="scripts.Native.ProcessTransactionTests">
                    <methods>
                        <include name="PGP_27715_validateOnlyEMIMerchantwithCorporateBin"/>
                        <include name="PGP_27715_validateOnlyEMIDCMerchantwithCorporateBin"/>
                    </methods>
                </class>
            </classes>
        </parameter>
    </test>

    <test name="PGP-27715 Corporate Card EMI Only Native+">
        <parameter name="isNativePlus" value="true">
            <classes>
                <class name="scripts.Native.ProcessTransactionTests">
                    <methods>
                        <include name="PGP_27715_validateOnlyEMIMerchantwithCorporateBin"/>
                        <include name="PGP_27715_validateOnlyEMIDCMerchantwithCorporateBin"/>
                    </methods>
                </class>
            </classes>
        </parameter>
    </test>
</suite>