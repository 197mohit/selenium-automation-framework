            </class>
        </classes>
    </test>
    <test name="PGP-35247 Subscription UI / UX - 1">
        <parameter name="theme" value="checkoutjs_web_revamp"/>
        <classes>
            <class name="scripts.SubscriptionBlinkCheckout">
                <methods>
                    <include name="PGP_35247_TC_02_MONTH"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>