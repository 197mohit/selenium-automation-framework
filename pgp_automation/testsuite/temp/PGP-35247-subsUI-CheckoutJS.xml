<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="PGP-35247 Subscription UI / UX" verbose="1" parallel="tests" thread-count="3">
    <test name="PGP-35247 Subscription UI / UX">
        <parameter name="theme" value="checkoutjs_web_revamp"/>
        <classes>
            <class name="scripts.SubscriptionBlinkCheckout">
                <methods>
                    <include name="PGP_35247_TC_01_YEAR"/>
                    <include name="PGP_35247_TC_03_DAY"/>
                    <include name="PGP_35247_TC_04_FIX"/>
                    <include name="PGP_35247_TC_05_ONDEMAND"/>
