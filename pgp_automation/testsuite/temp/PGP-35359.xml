<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="PGP-35359" verbose="1">
    <test name="Login Screen changes for checkoutJS">
        <parameter name="theme" value="checkoutjs_web_revamp"/>
        <classes>
            <class name="scripts.Native.checkoutjs.CheckoutJsTests">
                <methods>
                    <include name="LoginScreenChanges"/>
                </methods>
            </class>
        </classes>
    </test>
<test name="Login Screen changes for Enhanched Web">
    <parameter name="theme" value="enhancedweb_revamp"/>
    <classes>
        <class name="scripts.PGOnly">
            <methods>
                <include name="loginScreenChanges"/>
            </methods>
        </class>
    </classes>
</test>
</suite>





