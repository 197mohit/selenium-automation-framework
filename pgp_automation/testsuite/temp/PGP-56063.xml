<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="EMICardBinInUnified" verbose="1" parallel="methods" thread-count="2">
    <test name="Card Bin sent in Offer Checkout">
        <classes>
            <class name="scripts.api.PromoAndEmiSubvention.TestUnifiedFlows">
