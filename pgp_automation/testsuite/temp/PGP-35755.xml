<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Autologin checkoutjs" verbose="1">
    <test name="Checkoutjs Autologin ">
        <parameter name="theme" value="checkoutjs_web_revamp"/>
        <classes>
            <class name="scripts.Autologin.AutoLoginCheckoutJS">
                <methods>
                    <include name="autoLoginforcheckoutjsremembermeboxisunchecked"/>
                    <include name="autoLoginaftercookiecleared"/>
                    <include name="autologinforcheckoutjs"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>