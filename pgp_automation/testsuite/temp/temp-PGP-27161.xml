<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="PGP-27161 Verify Subscription Error Message(TxnAmt=MaxAmt=0)" verbose="1" parallel="methods" thread-count="1">
    <test name="Verify Subscription Error Message(TxnAmt=MaxAmt=0) for Enhanced">
        <classes>
            <class name="scripts.subscription.subscriptionFirstRequest.enhancedFlows.SubscriptionViaCcDc">
                <methods>
                    <include name="verifyErrorMessageWhenMaxAmtandTxnAmtisZeroTypeVARIABLE"/>
                    <include name="verifyErrorMessageWhenMaxAmtandTxnAmtisZeroTypeFIX"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="Verify Subscription Error Message(TxnAmt=MaxAmt=0) for Native">
        <classes>
            <class name="scripts.Native.subscription.NativeProcessSubscription">
                <methods>
                    <include name="verifyErrorMessageWhenMaxAmtandTxnAmtisZeroTypeVARIABLE"/>
                    <include name="verifyErrorMessageWhenMaxAmtandTxnAmtisZeroTypeFIX"/>
                </methods>
            </class>
        </classes>
    </test>

</suite>