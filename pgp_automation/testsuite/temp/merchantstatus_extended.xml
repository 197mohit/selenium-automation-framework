<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<!--
  merchantstatus_extended.xml
  Extended merchant-status suite covering payment-mode gaps, branch-coverage negative paths,
  and new recovery/security tests.

  Run with:
    mvn clean test -DsuiteXmlFile=testsuite/temp/merchantstatus_extended.xml \
      -Denv=staging -Dbrowser=chrome

  Test IDs covered:
    MS-NEW-02..04e  RecoveryStatusTests: active negative + body/JsonData mismatch + blank MID
    MS-NEW-04..08   DC, NB, refund paths in MerchantStatusTests
    MS-NEW-17       UPI path in MerchantStatusTests
    MS-NEW-21..23   Security/negative paths in MerchantStatusTests
    MS-NEW-26..33   Branch-coverage negative paths across all endpoints
    MS-BRANCH-01..07 ChecksumFilter + MerchantTxnStatusServiceImpl + MerchantOrderStatusImpl branches
    MS-NEW-24..25   PromoMerchantStatusTests (disabled until promo merchant available)
-->
<suite name="MerchantStatus_Extended_Suite" verbose="1" thread-count="8" parallel="tests">

    <!-- ===== RecoveryStatusTests: active negative + security tests ===== -->
    <test name="RecoveryStatus - OrderNotFound">
        <classes>
            <class name="scripts.merchantStatus.RecoveryStatusTests">
                <methods>
                    <include name="recoveryStatus_OrderNotFound"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="RecoveryStatus - MissingDeductionType">
        <classes>
            <class name="scripts.merchantStatus.RecoveryStatusTests">
                <methods>
                    <include name="recoveryStatus_MissingDeductionType"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="RecoveryStatus - ChecksumMismatch">
        <classes>
            <class name="scripts.merchantStatus.RecoveryStatusTests">
                <methods>
                    <include name="recoveryStatus_ChecksumMismatch"/>
                </methods>
            </class>
        </classes>
    </test>

    <!-- ===== MerchantStatusTests: new DC / NB / Refund tests ===== -->
    <test name="MerchantStatus - DC Success (getTxnStatus)">
