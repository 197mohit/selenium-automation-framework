<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="PGP-20549" verbose="1" thread-count="3"
       parallel="methods">
    <test name="PGP-20549:a percentage sign in init txn for Deffered Flow for native">
        <parameter name="isNativePlus" value="true"/>
        <classes>
            <class name="scripts.DeferredCheckout">
                <methods>
                    <include name="succesfulOrderwhenApercentagesSignInInitForDeferred"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="PGP-20549:a percentage sign in init txn for Deffered Flow for native +">
        <parameter name="isNativePlus" value="true"/>
        <classes>
            <class name="scripts.DeferredCheckout">
                <methods>
                    <include name="succesfulOrderwhenApercentagesSignInInitForDeferred"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="PGP-20549:a percentage sign in init txn for Native plus Flow">
        <parameter name="isNativePlus" value="true"/>
        <classes>
            <class name="scripts.Native.ProcessTransactionTests">
                <methods>
                    <include name="succesfulOrderwhenApercentagesSignInInitForPromoFlow"/>
                    <include name="succesfulOrderwhenApercentagesSignInInit"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="PGP-20549:a percentage sign in init txn for Native Flow">
        <parameter name="isNativePlus" value="false"/>
        <classes>
            <class name="scripts.Native.ProcessTransactionTests">
                <methods>
                    <include name="succesfulOrderwhenApercentagesSignInInitForPromoFlow"/>
                    <include name="succesfulOrderwhenApercentagesSignInInit"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>

