<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">

<suite name="Bin-Client-Removal" verbose="1">

  <test name="PGP-55308">

    <classes>
      <class name="scripts.Native.FetchBinDetails">
        <methods>
          <include name="ValidateHitIsGoingOnBinAPIInsteadOfBinClient"/>
          <include name="ValidateDataIsPickedFromCache"/>
        </methods>
      </class>

      <class name="scripts.api.theia.FetchBinAppDetails">
        <methods>
          <include name="verifyBinCenterApiCallIsHappening"/>
          <include name="ValidateDataIsPickedFromCache"/>
        </methods>
      </class>

    </classes>
  </test>
</suite>
