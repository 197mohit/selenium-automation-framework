<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="temp-AddMoneyWalletPcf">
    <test name="add money wallet pcf for enhanceweb">
        <parameter name="theme" value="enhancedweb"/>
        <classes>
            <class name="scripts.PostCovEnhance">
                <methods>
                    <include name="verifyAddNMoneywithDCwihDCpresentOnMerchant"/>
                    <include name="verifyAddNMoneywithDC"/>
                    <include name="validateAddmoneyWalletMerchantPCF"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="add money wallet pcf for enhancewap">
        <parameter name="theme" value="enhancedwap"/>
        <parameter name="mobileEmulation" value="Nexus 5"/>
        <parameter name="userAgent"
                   value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
        <classes>
            <class name="scripts.PostCovEnhance">
                <methods>
                    <include name="verifyAddNMoneywithDCwihDCpresentOnMerchant"/>
                    <include name="verifyAddNMoneywithDC"/>
                    <include name="validateAddmoneyWalletMerchantPCF"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="add money wallet pcf for Native">
        <parameter name="isNativePlus" value="false"/>
        <classes>
            <class name="scripts.Native.PCFNative">
                <methods>
                    <include name="TC_AddMOneyWalletOnlyPCFMerchant"/>
                    <include name="TC_AddMOneyWithDCAcquiringPCFMerchant"/>
                    <include name="TC_AddMOneyWithDCAcquiringNonPCFMerchant"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="add money wallet pcf for Native plus">
        <parameter name="isNativePlus" value="true"/>
        <classes>
            <class name="scripts.Native.PCFNative">
                <methods>
                    <include name="TC_AddMOneyWalletOnlyPCFMerchant"/>
                    <include name="TC_AddMOneyWithDCAcquiringPCFMerchant"/>
                    <include name="TC_AddMOneyWithDCAcquiringNonPCFMerchant"/>
                </methods>
            </class>
        </classes>
    </test>


    <test name="add money wallet pcf for Native plus deferred flow">
        <parameter name="isNativePlus" value="true"/>
        <classes>
            <class name="scripts.DeferredCheckout">
                <methods>
                    <include name="validateDCTxn_DeferredCheckout_WithAmountInFetchPayOptionForPCFMerchant"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="add money wallet pcf for Native deffered flow">
        <parameter name="isNativePlus" value="false"/>
        <classes>
            <class name="scripts.DeferredCheckout">
                <methods>
                    <include name="validateDCTxn_DeferredCheckout_WithAmountInFetchPayOptionForPCFMerchant"/>
                </methods>
            </class>
        </classes>
    </test>


</suite>