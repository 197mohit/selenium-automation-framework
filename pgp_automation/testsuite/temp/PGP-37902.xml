<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="PGP-37902" verbose="1">
    <test name="PGP-37902 on checkoutJS">
        <parameter name="theme" value="checkoutjs_web_revamp"/>
        <classes>
            <class name="scripts.SubscriptionBlinkCheckout">
                <methods>
                    <include name="verify_closed_wallet_user_error_message_SubsFlow"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="PGP-37902 on enhanced">
        <parameter name="theme" value="enhancedweb_revamp"/>
        <classes>
            <class name="scripts.subscription.subscriptionFirstRequest.defaultFlows.SubscriptionViaWalletOnly">
                <methods>
                    <include name="verify_closed_wallet_user_error_message_SubsFlow"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>
