<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="PGP-21603 - Autologin" verbose="1" thread-count="6" parallel="methods">
    <test name="Autologin Tests - EnhancedWeb">
        <parameter name="theme" value="enhancedweb"/>
        <classes>
            <class name="scripts.Autologin.AutoLogin">
                <methods>
                    <include name="autologin_enhancedSubscriptionFlow"/>
                    <include name="autologin_validateRememberMeNotVisible"/>
                    <include name="autologin_validateSecondUser"/>
                    <include name="autologin_afterClearCookie"/>
                    <include name="autologin_anotherMerchant"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="Autologin Tests - EnhancedWap">
        <parameter name="theme" value="enhancedwap"/>
        <classes>
            <class name="scripts.Autologin.AutoLogin">
                <methods>
                    <include name="autologin_enhancedSubscriptionFlow"/>
                    <include name="autologin_validateRememberMeNotVisible"/>
                    <include name="autologin_validateSecondUser"/>
                    <include name="autologin_afterClearCookie"/>
                    <include name="autologin_anotherMerchant"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>