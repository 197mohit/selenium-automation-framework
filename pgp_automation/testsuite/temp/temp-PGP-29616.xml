<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="PGP-29616" verbose="1" parallel="methods" thread-count="1">
    <test name="New Field UDF_2 CheckoutJS Wap">
        <parameter name="theme" value="checkoutjs_wap"/>
        <parameter name="userAgent"
                   value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
        <classes>
            <class name="scripts.Native.checkoutjs.CheckoutJsTests">
                <methods>
                    <include name="ValidateSuccessTxnUsingCCWhichNewUDFParam"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="New Field UDF_2 CheckoutJS Web">
        <parameter name="theme" value="checkoutjs_web"/>
        <classes>
            <class name="scripts.Native.checkoutjs.CheckoutJsTests">
                <methods>
                    <include name="ValidateSuccessTxnUsingCCWhichNewUDFParam"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="New Field UDF_2 App Invoke">
        <classes>
            <class name="scripts.Native.FetchPaymentPage">
                <methods>
                    <include name="FPP_validateAdditionalParamUDFInAppInvokeFlow"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="New Field Seamless">
        <classes>
            <class name="scripts.MDRPCF.MDRPCF">
                <methods>
                    <include name="successfulSeamlessWithNewFieldUDFTxnWithCC"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="New Field PG only for enhancedweb">
        <parameter name="theme" value="enhancedweb"/>
        <classes>
            <class name="scripts.PGOnly">
                <methods>
                    <include name="testNewlyAddedUDF2Params"/>
                </methods>
            </class>
        </classes>
    </test>


    <test name="New Field PG only enhancedwap">
        <parameter name="theme" value="enhancedwap"/>
        <parameter name="mobileEmulation" value="Nexus 5"/>
        <parameter name="userAgent"
                   value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
        <classes>
            <class name="scripts.PGOnly">
                <methods>
                    <include name="testNewlyAddedUDF2Params"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="testNewFieldUDF_2 - Native">
        <parameter name="isNativePlus" value="false">
            <classes>
                <class name="scripts.Native.ProcessTransactionTests">
                    <methods>
                        <include name="testNewFieldUDF_2"/>
                    </methods>
                </class>
            </classes>
        </parameter>
    </test>


    <test name="testNewFieldUDF_2 - Native plus">
        <parameter name="isNativePlus" value="true">
            <classes>
                <class name="scripts.Native.ProcessTransactionTests">
                    <methods>
                        <include name="testNewFieldUDF_2"/>
                    </methods>
                </class>
            </classes>
        </parameter>
    </test>



    <test name="PGP-28523 - Result code Mapping">
        <parameter name="isNativePlus" value="true">
            <classes>
                <class name="scripts.Native.subscription.NativeProcessSubscription">
                    <methods>
                        <include name="verifyErrorMessageWhenReqTypeIsInvalid"/>
                        <include name="TC_validateFailedDuringCreateSubs"/>
                    </methods>
                </class>
            </classes>
        </parameter>
    </test>
</suite>