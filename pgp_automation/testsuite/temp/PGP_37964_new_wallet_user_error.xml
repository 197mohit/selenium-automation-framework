<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="PGP-37964" verbose="1" parallel="tests" thread-count="2">
    <test name="Verify for new wallet user RBI guidelines error message should be shown">
        <parameter name="theme" value="checkoutjs_web_revamp"/>
        <classes>
            <class name="scripts.Native.checkoutjs.CheckoutJsTests">
                <methods>
                    <include name="verify_new_wallet_user_error_message"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="PGP-36669 verifying_paytmPgLogo_displayedEnhanced">
        <parameter name="theme" value="enhancedweb_revamp"/>
        <classes>
            <class name="scripts.PGOnly">
                <methods>
                    <include name="verify_new_wallet_user_error_message"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>