<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="EMI Suite PCF and Minimal Cases and Fixes">
    <test name="Js Checkout cases PCF">
        <parameter name="JsType" value="checkoutjs"/>
        <classes>
            <class name="scripts.EMITest.CheckoutJS.EMICheckoutJsNewFlowTest">
                <methods>
                    <include name="testJsCheckoutNewFlow_CC_with_Offer_and_PCF"/>
                    <include name="testJsCheckoutNewFlow_NB_with_Offer_and_PCF"/>
                    <include name="testJsCheckoutNewFlow_EMI_with_Offer_and_PCF"/>
                    <include name="testJsCheckoutNewFlow_EMI_DC_with_Offer_and_PCF"/>
                    <include name="testJsCheckoutNewFlow_EMI_Bank_Flow_with_Offer_and_PCF"/>
                </methods>
            </class>
            <class name="scripts.EMITest.CheckoutJS.EMICheckoutJsOldFlowTest">
                <methods>
                    <include name="testJsCheckoutOldFlow_CC_with_Offer_and_PCF"/>
                    <include name="testJsCheckoutOldFlow_NB_with_Offer_and_PCF"/>
                    <include name="testJsCheckoutOldFlow_EMI_with_Offer_and_PCF"/>
                    <include name="testJsCheckoutOldFlow_EMI_DC_with_Offer_and_PCF"/>
                    <include name="testJsCheckoutOldFlow_EMI_Bank_Flow_with_Offer_and_PCF"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="Js Checkout MINIMAL preference Merchants">
        <parameter name="JsType" value="checkoutjs"/>
        <classes>
            <class name="scripts.EMITest.CheckoutJS.EMICheckoutJsNewFlowTest">
                <methods>
                    <include name="testJsCheckoutNewFlow_EMI_MINIMAL_PROMO_MERCHANT"/>
                    <include name="testJsCheckoutNewFlow_CC_MINIMAL_PROMO_MERCHANT"/>
                    <include name="testJsCheckoutNewFlow_EMI_MINIMAL_SUBVENTION_MERCHANT"/>
                    <include name="testJsCheckoutNewFlow_CC_MINIMAL_SUBVENTION_MERCHANT"/>
                    <include name="testJsCheckoutNewFlow_EMI_MINIMAL_SUBVENTION_PROMO_MERCHANT"/>
                    <include name="testJsCheckoutNewFlow_CC_MINIMAL_SUBVENTION_PROMO_MERCHANT"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="EMI Fixes">
        <parameter name="JsType" value="checkoutjs"/>
        <classes>
            <class name="scripts.EMITest.CheckoutJS.EMICheckoutJsNewFlowTest">
                <methods>
                    <include name="testJsCheckoutNewFlow_UPI_with_Offer"/>
                </methods>
            </class>
            <class name="scripts.EMITest.CheckoutJS.EMICheckoutJsOldFlowTest">
                <methods>
                    <include name="testJsCheckoutOldFlow_UPI_with_Offer"/>
                </methods>
            </class>
            <class name="scripts.MDRPCF.MDRPCFNative">
                <methods>
                    <include name="validateFetchBinDetailsResponseForCardNetworkDiners"/>
                    <include name="validatePTCResponseForCardNetworkDiners"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>