<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="PGP-35819">
    <test name="Verify AddnPay via CC limit message">
        <parameter name="theme" value="enhancedweb_revamp"/>
        <classes>
            <class name="scripts.AddNPay">
                <methods>
                    <include name="validateAddnPayViaCCDynamicLimit"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="Verify AddnPay via CC limit message and do txn with DC">
        <parameter name="theme" value="enhancedwap_revamp"/>
        <parameter name="mobileEmulation" value="Nexus 5"/>
        <parameter name="userAgent"
                   value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
        <classes>
            <class name="scripts.AddNPay">
                <methods>
                    <include name="validateAddnPayViaCCDynamicLimit_successTxn"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="Verify AddnPay via CC limit message checkoutJS">
        <parameter name="theme" value="checkoutjs_web_revamp"/>
        <classes>
            <class name="scripts.Native.checkoutjs.CheckoutJsTests">
                <methods>
                    <include name="validateAddnPayViaCCDynamicLimit_CWEB"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="Verify AddnPay via CC limit message checkoutJS and validate success txn">
        <parameter name="theme" value="checkoutjs_wap_revamp"/>
        <parameter name="mobileEmulation" value="Nexus 5"/>
        <parameter name="userAgent"
                   value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
        <classes>
            <class name="scripts.Native.checkoutjs.CheckoutJsTests">
                <methods>
                    <include name="validateAddnPayViaCCDynamicLimit_CWAP"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>