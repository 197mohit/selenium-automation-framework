<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Refund_Triaging" verbose="1" thread-count="10"
       parallel="tests">
    <test name="Refund_with_enhancedweb">
        <parameter name="theme" value="enhancedweb_revamp"/>
        <classes>
            <class name="scripts.Refund">
                <methods>
                    <include name="successfulHybridRefund"/>
                    <include name="verifyRefundFailureOfAlreadySuccessfulRefund"/>
                    <include name="successfulAddNPayRefund"/>
                </methods>
            </class>
        </classes>
    </test>


    <test name="RefundAsync_with_enhancedweb">
        <parameter name="theme" value="enhancedweb_revamp"/>
        <classes>
            <class name="scripts.RefundAsync">
                <methods>

                    <include name="successfulHybridRefund_async"/>
                    <include name="successfulAddNPayRefund_async"/>
                    <include name="verifyRefundFailureOfAlreadySuccessfulRefund_async"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="Refund-enhancedwap">
        <parameter name="theme" value="enhancedwap_revamp"/>
        <parameter name="mobileEmulation" value="Nexus 5"/>
        <parameter name="userAgent" value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
        <classes>
            <class name="scripts.Refund">
                <methods>
                    <include name="successfulHybridRefund"/>
                    <include name="verifyRefundFailureOfAlreadySuccessfulRefund"/>
                    <include name="successfulAddNPayRefund"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="RefundAsync-enhancedwap">
        <parameter name="theme" value="enhancedwap_revamp"/>
        <parameter name="mobileEmulation" value="Nexus 5"/>
        <parameter name="userAgent" value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
        <classes>
            <class name="scripts.RefundAsync">
                <methods>
                    <include name="successfulHybridRefund_async"/>
                    <include name="successfulAddNPayRefund_async"/>
                    <include name="verifyRefundFailureOfAlreadySuccessfulRefund_async"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>