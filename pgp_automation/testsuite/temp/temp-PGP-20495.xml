<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="PGP-20495 - Promo - SimpliFiedPaymentOffers" verbose="1" thread-count="3"
       parallel="methods">
    <test name="PGP-20495 - Promo - SimpliFiedPaymentOffers Tests for native">
        <parameter name="isNativePlus" value="false"/>
        <classes>
            <class name="scripts.Native.FetchPromoCodeDetails">
                <methods>
                    <include name="ValidateFailureTxnUsingPaymentandSimplifiedoffers"/>
                    <include name="ValidateSuccessTxnUsingSpecificCashbackPromoInNewFlow"/>
                    <include name="ValidateSuccessTxnUsingSpecificDiscountPromoInNewFlow"/>
                    <include name="ValidateSuccessTxnUsingAnyAvailablePromoInNewFlow"/>
                    <include name="ValidateMerchantRetryNotAllowedUsingAnyAvailablePromoInNewFlow"/>
                    <include name="ValidateFailureTxnUsingInvalidPromoWithValidatePromoTrueInNewFlow"/>
                    <include name="ValidateSuccessTxnUsingInvalidPromoWithValidatePromoFalseInNewFlow"/>
                    <include name="ValidateFailureTxnUsingNullPromoParamsInNewFlow"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="PGP-20495 - Promo - SimpliFiedPaymentOffers Tests for Native Plus">
        <parameter name="isNativePlus" value="true"/>
        <classes>
            <class name="scripts.Native.FetchPromoCodeDetails">
                <methods>
                    <include name="ValidateFailureTxnUsingPaymentandSimplifiedoffers"/>
                    <include name="ValidateSuccessTxnUsingSpecificCashbackPromoInNewFlow"/>
                    <include name="ValidateSuccessTxnUsingSpecificDiscountPromoInNewFlow"/>
                    <include name="ValidateSuccessTxnUsingAnyAvailablePromoInNewFlow"/>
                    <include name="ValidateMerchantRetryNotAllowedUsingAnyAvailablePromoInNewFlow"/>
                    <include name="ValidateFailureTxnUsingInvalidPromoWithValidatePromoTrueInNewFlow"/>
                    <include name="ValidateSuccessTxnUsingInvalidPromoWithValidatePromoFalseInNewFlow"/>
                    <include name="ValidateFailureTxnUsingNullPromoParamsInNewFlow"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="PGP-20495 - Promo - SimpliFiedPaymentOffers Tests - DirectBankTest">
        <classes>
            <class name="scripts.PGDirectHddo">
                <methods>
                    <include name="verifySuccessfulPromoTxn"/>
                </methods>
            </class>
        </classes>
    </test>

</suite>