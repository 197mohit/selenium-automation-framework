<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="PGP-24378" verbose="1" parallel="methods"  thread-count="20">
    <test name="PGP-24378 for enhanceweb">
        <parameter name="theme" value="enhancedweb"/>
        <classes>
            <class name="scripts.PGOnly">
                <methods>
                    <include name="verifyResponseForCancelTxnWhenFf4jFlagIsOff"/>
                    <include name="verifyResponseForCancelTxnWhenFf4jFlagIsOn"/>
                    <include name="verifyResponseForCancelTxnWhenFf4jFlagIsOnTxnTokenNull"/>
                    <include name="verifyResponseForCancelTxnWhenFf4jFlagIsOnTxnTokenTampered"/>
                    <include name="verifyResponseForCancelTxnWhenFf4jFlagIsOFFForRiskAmount"/>
                    <include name="verifyResponseForCancelTxnWhenFf4jFlagIsONForRiskAmount"/>
                    <include name="verifyResponseForCancelTxnWhenFf4jFlagIsONForRiskAmountTxnisNull"/>
                    <include name="verifyResponseForCancelTxnWhenFf4jFlagIsONForRiskAmountTxnisTampered"/>
                    <include name="verifyResponseForCancelenFf4jFlagIsOFFForBasicKYC"/>
                    <include name="verifyResponseForCancelenFf4jFlagIsONForBasicKYC"/>
                    <include name="verifyResponseForCancelTxnWhenFf4jFlagIsONForBasicKYCTxnisNull"/>
                    <include name="verifyResponseForCancelTxnWhenFf4jFlagIsONForBasicKYCTxnisTampered"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="PGP-24378 for enhancewap">
        <parameter name="theme" value="enhancedwap"/>
        <parameter name="mobileEmulation" value="Nexus 5"/>
        <parameter name="userAgent"
                   value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
        <classes>
            <class name="scripts.PGOnly">
                <methods>
                    <include name="verifyResponseForCancelTxnWhenFf4jFlagIsOff"/>
                    <include name="verifyResponseForCancelTxnWhenFf4jFlagIsOn"/>
                    <include name="verifyResponseForCancelTxnWhenFf4jFlagIsOnTxnTokenNull"/>
                    <include name="verifyResponseForCancelTxnWhenFf4jFlagIsOnTxnTokenTampered"/>
                    <include name="verifyResponseForCancelTxnWhenFf4jFlagIsOFFForRiskAmount"/>
                    <include name="verifyResponseForCancelTxnWhenFf4jFlagIsONForRiskAmount"/>
                    <include name="verifyResponseForCancelTxnWhenFf4jFlagIsONForRiskAmountTxnisNull"/>
                    <include name="verifyResponseForCancelTxnWhenFf4jFlagIsONForRiskAmountTxnisTampered"/>
                    <include name="verifyResponseForCancelenFf4jFlagIsOFFForBasicKYC"/>
                    <include name="verifyResponseForCancelenFf4jFlagIsONForBasicKYC"/>
                    <include name="verifyResponseForCancelTxnWhenFf4jFlagIsONForBasicKYCTxnisNull"/>
                    <include name="verifyResponseForCancelTxnWhenFf4jFlagIsONForBasicKYCTxnisTampered"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>
