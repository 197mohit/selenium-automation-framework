<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="EMI Fix" verbose="1">
    <test name="EMI Fix" parallel="methods" thread-count="14">
        <parameter name="theme" value="checkoutjs_web_revamp"/>
        <classes>
            <class name="scripts.Native.checkoutjs.CheckoutJsEMITests">
                <methods>
                    <include name="AmountBasedEMIOnCheckoutJs"/>
                    <include name="ItemBasedEMIOnCheckoutJs"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="EMISubvention">
        <parameter name="isNativePlus" value="false"/>
        <classes>
            <class name="scripts.EMISubvention">
                <methods>
                    <include name="verifyBAJAJEMIWithEMIID"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="EMISubventionTXN">
        <parameter name="theme" value="enhancedweb_revamp"/>
        <classes>
            <class name="scripts.EMISubventionTxnTokenFlow">
                <methods>
                    <include name="emisub29"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>