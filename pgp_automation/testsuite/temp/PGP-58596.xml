                    <include name="verifyFPOwithDisabledsavedBinUpiPaymodewith6DigitsBins"/>
                    <include name="verifyFPOwithDisabledsavedBinUpiPaymode"/>
                    <include name="verifyFPOwithEnabledsavedBinUpiPaymodewith6DigitsBins"/>
