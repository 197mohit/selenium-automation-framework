<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="GoodsInfoCheck" verbose="1">
    <test name="GoodsInfoCheck_enhancedweb">
        <parameter name="theme" value="enhancedweb"/>
        <classes>
            <class name="scripts.GoodsInfoCheck">
                <methods>
                    <include name="enhanced01"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="GoodsInfoCheck_nativeplus">
        <parameter name="isNativePlus" value="true"/>
        <classes>
            <class name="scripts.GoodsInfoCheck">
                <methods>
                    <include name="nativePlus01"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="GoodsInfoCheck_appinvoke">
        <parameter name="theme" value="enhancedwap"/>
        <parameter name="userAgent"
                   value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
        <classes>
            <class name="scripts.GoodsInfoCheck">
                <methods>
                    <include name="showPaymentPage01"/>
                </methods>
            </class>
        </classes>
    </test>

</suite>