<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="PGP-22755 PCF for NB, PPBL Suite" verbose="1" parallel="methods" thread-count="2">
    <test name="PGP-22755 Tests on EnhancedWap">
        <parameter name="theme" value="enhancedwap"/>
        <parameter name="mobileEmulation" value="Nexus 5"/>
        <parameter name="userAgent"
                   value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
        <classes>
            <class name="scripts.PGOnly">
                <methods>
                    <include name="validateSucessfullPCFTransactionviaICICINB"/>
                    <include name="validateSucessfullPCFTransactionviaPPBL"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="PGP-22755 Tests on EnhancedWeb">
        <parameter name="theme" value="enhancedweb"/>
        <classes>
            <class name="scripts.PGOnly">
                <methods>
                    <include name="validateSucessfullPCFTransactionviaICICINB"/>
                    <include name="validateSucessfullPCFTransactionviaPPBL"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="PGP-22755 Tests on Native">
        <parameter name="isNativePlus" value="false"/>
        <classes>
            <class name="scripts.Native.ProcessTransactionTests">
                <methods>
                    <include name="validateSucessfullPCFTransactionviaICICINB"/>
                    <include name="validateSucessfullPCFTransactionviaPPBL"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="PGP-22755 Tests on Native Plus">
        <parameter name="isNativePlus" value="true"/>
        <classes>
            <class name="scripts.Native.ProcessTransactionTests">
                <methods>
                    <include name="validateSucessfullPCFTransactionviaICICINB"/>
                    <include name="validateSucessfullPCFTransactionviaPPBL"/>
                </methods>
            </class>
        </classes>
    </test>
