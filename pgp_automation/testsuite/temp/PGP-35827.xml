<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="PGP-35827">
    <test name="Verify Subscription for 0.00 and 0.0 txn amount with different pay modes for enhancedweb revamp">
        <parameter name="theme" value="enhancedweb_revamp"/>
        <classes>
            <class name="scripts.EnhancedBankMandate">
                <methods>
                    <include name="verifySubscriptionCreatedFor0TxnAmtWithTwoDecimalPlacePayModeUPI"/>
                    <include name="verifySubscriptionCreatedFor0TxnAmtWithOneDecimalPlacePayModeUPI"/>
                    <include name="verifySubsFor0TxnAmtWithTwoDecimalPlacePayModeBlankAndPaymentThroughMandate"/>
                    <include name="verifySubsFor0TxnAmtWithTwoDecimalPlacePayModePPI"/>
                    <include name="verifySubsFor0TxnAmtWithTwoDecimalPlacePayModeBlankAndPaymentThroughPPI"/>
                    <include name="verifySubsFor0TxnAmtWithOneDecimalPlacePayModeBlankAndPaymentThroughPPI"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="Verify Subscription for 0.00 and 0.0 txn amount with different pay modes for enhancedwap revamp">
        <parameter name="theme" value="enhancedwap_revamp"/>
        <classes>
            <class name="scripts.EnhancedBankMandate">
                <methods>
                    <include name="verifySubscriptionCreatedFor0TxnAmtWithTwoDecimalPlacePayModeUPI"/>
                    <include name="verifySubscriptionCreatedFor0TxnAmtWithOneDecimalPlacePayModeUPI"/>
                    <include name="verifySubsFor0TxnAmtWithTwoDecimalPlacePayModeBlankAndPaymentThroughMandate"/>
                    <include name="verifySubsFor0TxnAmtWithTwoDecimalPlacePayModePPI"/>
                    <include name="verifySubsFor0TxnAmtWithTwoDecimalPlacePayModeBlankAndPaymentThroughPPI"/>
                    <include name="verifySubsFor0TxnAmtWithOneDecimalPlacePayModeBlankAndPaymentThroughPPI"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>