<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="PGPUI-1046 CheckoutJS UPI Intent UI Changes" verbose="1" parallel="methods" thread-count="1">
    <test name="CheckoutJS UPI Intent UI Changes">
        <parameter name="theme" value="checkoutjs_wap"/>
        <parameter name="userAgent"
                   value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
        <classes>
            <class name="scripts.Native.checkoutjs.CheckoutJsUPIIntent">
                <methods>
                    <include name="ValidateSuccessTxnUsingUPICollectwithIntentEnabled"/>
                    <include name="ValidateUPIPaymodeUIchangeswithUPIIntentEnabled"/>
                    <include name="ValidateUPICollectpaymodeNotVisiblewithIntentOnlyEnabled"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>