<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="PG Direct HDDO TestSuite" verbose="1" parallel="tests" thread-count="6">
    <test name="Direct HDDO Test cases - Enhancedweb">
        <parameter name="theme" value="enhancedweb"/>
        <classes>
            <class name="scripts.PGDirectHddo">
                <methods>
                    <include name="verifySuccessfulPGOnlyTxnHDFCCard"/>
                    <include name="verifySuccessfulPGOnlyTxnICICICard"/>
                    <include name="visibilityOfBankLogo"/>
                    <include name="ValidatewithInvalidOTP"/>
                    <include name="ValidateMerchantRetryBreach"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="Direct HDDO Test cases - Enhancedwap">
        <parameter name="theme" value="enhancedwap"/>
        <parameter name="mobileEmulation" value="Nexus 5"/>
        <parameter name="userAgent"
                   value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
        <classes>
            <class name="scripts.PGDirectHddo">
                <methods>
                    <include name="verifyGotoBankWebsiteLinkNotPresent"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="SLider OTP For EnhancedWap" parallel="methods" thread-count="5">
        <parameter name="theme" value="enhancedwap"/>
        <parameter name="mobileEmulation" value="Nexus 5"/>
        <parameter name="userAgent"
                   value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
        <classes>
            <class name="scripts.SliderOTP">
                <methods>
                    <include name="VerifyResendOTPbuttonNotVisibleHDDO"/>
                    <include name="ValidateForMerchantRetryAfterInvalidOTPLandToCashierPageforOTPSlider"/>
                    <include name="VerifyHeaderTextOnOTPSlider"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>