<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Redirection fixes" verbose="1">
    <test name="Performing Redirection fixes with web theme">
        <parameter name="theme" value="enhancedweb_revamp"/>
        <classes>
            <class name="scripts.PostCovEnhance">
                <methods>
                    <include name="verify_successful_NBTxnWithFlatCommsion"/>
                    <include name="Verify_numberOfFeeDisplayingIsEqualToNumberOfPayModeOnCashier"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="Performing Redirection fixes with wap theme">
        <parameter name="theme" value="enhancedwap_revamp"/>
        <classes>
            <class name="scripts.PostCovEnhance">
                <methods>
                    <include name="verify_successful_NBTxnWithFlatCommsion"/>
                    <include name="Verify_numberOfFeeDisplayingIsEqualToNumberOfPayModeOnCashier"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>