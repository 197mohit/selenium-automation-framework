<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="New_QR_Suite_PG2 " verbose="1" thread-count="20" parallel="tests">
    <parameter name="browser" value="chrome"/>
    <test name="PGP-42679">
        <classes>
            <class name="scripts.Qr.qr">
                <methods>
                    <include name="Verify_isAddMoneyPayOptionsAvailable_true_user_postpaid_merchant_nonpostpaid"/>
                    <include name="Verify_isAddMoneyPayOptionsAvailable_true_user_nonpostpaid_merchant_postpaid"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="PGP-44639 Static QR">
        <classes>
            <class name="scripts.DynamicQRNew">
                <methods>
                    <include name="verifyMerchantinfoDynamicQR"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="PGP-44639 DQR">
        <classes>
            <class name="scripts.StaticQRNew">
                <methods>
                    <include name="verifyMerchantinfoStaticQR"/>
                    <include name="verifyMerchantinfoStaticQRwallet"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="qrcodeId flow">
        <classes>
            <class name="scripts.Native.ProcessTransactionTests">
                <methods>
                    <include name="qrcodeIdUpiPushSuccessTxnStaticQr"/>
                    <include name="qrcodeIdUpiPushSuccessTxnDynamicQr"/>
                    <include name="qrcodeIdUpiPushSuccessTxnDynamicQrPcf"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="BffLayered field in FPO/FetchQrDetails">
        <classes>
            <class name="scripts.Qr.qr">
                <methods>
                    <include name="verify_bffLayerEnabled_in_FetchQRPaymentetails_FF4J_ON"/>
                    <include name="verify_bffLayerEnabled_in_FPO_FF4J_ON"/>
                    <include name="verify_bffLayerEnabled_in_FetchQRPaymentetails_FF4J_OFF"/>
                    <include name="verify_bffLayerEnabled_in_FPO_FF4J_OFF"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="PGP-42767 DQR Repeat Payment Issue">
        <classes>
            <class name="scripts.DynamicQRNew">
                <methods>
                    <include name="verifyRepeatDQRTxnQRDeeplinkParam"/>
                    <include name="verifyRepeatDQRTxnQRDeeplinkParamforUPI"/>
                    <include name="verifyRepeatDQRTxnQRDeeplinkParamforPPI"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="PGP-43468 - 1">
        <parameter name="theme" value="enhancedweb_revamp"/>
        <classes>
            <class name="scripts.UpiQrFlow">
                <methods>
                    <include name="TC01_ValidateQrIsNotDsiplayed"/>
                    <include name="TC02_ValidateQRisNotDisplayed_UPI_INACTIVE"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="PGP-43468 - 2">
        <parameter name="theme" value="checkoutjs_web_revamp"/>
        <classes>
            <class name="scripts.UpiQrFlow">
                <methods>
                    <include name="TC03_ValidateQRisNotDisplayed"/>
                    <include name="TC04_ValidateQRisNotDisplayed_UPI_INACTIVE"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="PGP-43468 - 3">
        <classes>
            <class name="scripts.UpiQrFlow">
                <methods>
                    <include name="TC05_ValidateQRisNotDisplayed_NATIVE"/>
                    <include name="TC06_ValidateQRisNotDisplayed_UPI_INACTIVE_NATIVE"/>
                </methods>
            </class>
        </classes>
    </test>

</suite>