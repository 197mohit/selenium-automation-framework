<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="PostPaid_Suite" verbose="1" thread-count="10" parallel="tests">

    <test name="PGP-33928 - Postpaid AddNpay checkoutJS web">
        <parameter name="theme" value="checkoutjs_web_revamp"/>
        <classes>
            <class name="scripts.Native.checkoutjs.checkoutJSPostpaidAddNPay">
                <methods>
                    <include name="postpaidSuccessTxn"/>
                    <include name="SuccessfulAddNPayPostpaidTxnForMIDNotHavingPostapidPaymode"/>
                    <include name="postpaidNotAvailableWhenDeselectedWallet"/>
                    <include name="SuccessfulAddNPayPostpaidTxnForMIDAndWalletMIDHavingPostapidPaymode"/>
                    <include name="SuccessfulPostpaidTxnForWalletDeselected"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="PGP-33928 - Postpaid AddNpay enhanced web">
        <parameter name="theme" value="enhancedweb_revamp"/>
        <classes>
            <class name="scripts.AddNPay">
                <methods>
                    <include name="SuccessfulAddNPayPostpaidTxnForMIDNotHavingPostapidPaymode"/>
                    <include name="postpaidNotAvailableWhenDeselectedWallet"/>
                    <include name="SuccessfulAddNPayPostpaidTxnForMIDAndWalletMIDHavingPostapidPaymode"/>
                    <include name="SuccessfulPostpaidTxnForWalletDeselected"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="PGP-33928 - Postpaid AddNpay enhanced wap">
        <parameter name="theme" value="enhancedwap_revamp"/>
        <parameter name="mobileEmulation" value="Nexus 5"/>
        <parameter name="userAgent"
                   value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
        <classes>
            <class name="scripts.AddNPay">
                <methods>
                    <include name="SuccessfulAddNPayPostpaidTxnForMIDNotHavingPostapidPaymode"/>
                    <include name="postpaidNotAvailableWhenDeselectedWallet"/>
                    <include name="SuccessfulAddNPayPostpaidTxnForMIDAndWalletMIDHavingPostapidPaymode"/>
                    <include name="SuccessfulPostpaidTxnForWalletDeselected"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="PGP-34038 - Mapping Merchant Profile API Tests for postpaid">
        <classes>
            <class name="scripts.api.mappingService.MerchantProfilePostpaidOnAddNPay"/>
        </classes>
    </test>

    <test name="PaytmCC with enhancedweb">
        <parameter name="theme" value="enhancedweb_revamp"/>
        <classes>
            <class name="scripts.PaytmDigitalCard">
                <methods>
                    <!-- Exclude Zero Pass Percentage TCs -->
                    <exclude name="PGP_482_NoResponseFromPaytmCC"/>
                    <exclude name="PGP_514_PostPaidSelectWhenWalletBalanceZero"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="PaytmCC-enhancedwap">
        <parameter name="theme" value="enhancedwap_revamp"/>
        <parameter name="mobileEmulation" value="Nexus 5"/>
        <parameter name="userAgent"
                   value="Mozilla/5.0 (iPhone; CPU iPhone OS 6_0 like Mac OS X) AppleWebKit/536.26 (KHTML,like Gecko) Version/6.0 Mobile/10A5376e Safari/8536.25"/>
        <classes>
            <class name="scripts.PaytmDigitalCard">
                <methods>
                    <!-- Exclude Zero Pass Percentage TCs -->
                    <exclude name="PGP_514_PostPaidSelectWhenWalletBalanceZero"/>
                    <exclude name="PGP_482_NoResponseFromPaytmCC"/>
                </methods>
            </class>
        </classes>
    </test>



