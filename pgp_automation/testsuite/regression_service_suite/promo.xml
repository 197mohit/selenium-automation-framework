                    <include name='test when body.fetchAllPaymentOffers = true given merchant has promos configured and body.simplifiedPaymentOffers.promoCode equals invalid promo in Initiate Txn API'/>
                    <include name='test when body.fetchAllPaymentOffers = false given merchant has promos configured'/>
