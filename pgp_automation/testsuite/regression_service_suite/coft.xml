<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="COFT" verbose="1" thread-count="20" parallel="tests">
    <test name="PTS">
        <classes>
            <class name="scripts.coft.pts.TokenizeCardTests"/>
            <class name="scripts.coft.pts.TokenizeDirectCardTests"/>
            <class name="scripts.coft.pts.ModifyTokenStatusTests"/>
            <class name="scripts.coft.pts.ModifyTokenRevampStatusTests"/>
            <class name="scripts.coft.pts.GenerateTokenDataTests"/>
            <class name="scripts.coft.pts.FetchTokenDetailsTests"/>
            <class name="scripts.coft.pts.FetchPendingTokensTests"/>
            <class name="scripts.coft.pts.ExtendGenerateTokenDataTests"/>
            <class name="scripts.coft.pts.CardToParTests"/>
        </classes>
    </test>

    <test name="Theia_Coft">
        <classes>
            <class name="scripts.coft.theia.CoftFetchPayOptions"/>
        </classes>
    </test>

    <test name="Account Bin Range">
        <classes>
            <class name="scripts.AccountBinRange.AccountBinRanges"/>
        </classes>
    </test>

    <test name="Feature">
        <classes>
            <class name="scripts.coft.theia.PTCReqValidationTokenTavvTests">
            </class>
        </classes>
    </test>

    <test name="theiaRiskInt">
        <classes>
            <class name="scripts.coft.theia.TheiaRiskIntegrationTests">
            </class>
        </classes>
    </test>

    <test name="Verify coft fetch bin changes">
        <classes>
            <class name="scripts.coft.theia.Fetch_Bin_Change">
            </class>
        </classes>
    </test>

    <test name="Verify tokenisation api network error codes">
        <classes>
            <class name="scripts.coft.pts.ErrorMessagingInTokenisationFailure">
            </class>
        </classes>
    </test>

    <test name="SaveCardAuthenticationTestCases">
        <classes>
            <class name="scripts.coft.savedCardService.SavedCardByUserIdTests">
                <methods>
                    <include name="VerifySuccessFullTxnWithUserIdWhereJwtFromVault"/>
                    <include name="VerifySavedCardDetailsWithUserIdAndInvalidJwt"/>
                </methods>
            </class>
            <class name="scripts.coft.savedCardService.SavedCardByMidCustIdTests">
                <methods>
                    <include name="VerifySuccessFullTxnWhereJwtFromVault"/>
                    <include name="VerifySavedCardDetailsWithInvalidJWTFromVault"/>
                    <include name="VerifySuccessFullTxnWithCheksum"/>
                </methods>
            </class>
            <class name="scripts.coft.savedCardService.DeleteCardbyMidCustIdTest">
                <methods>
                    <include name="VerifySuccessFullTxnDeleteCardWhereJwtFromVault"/>
                    <include name="VerifyDeleteCardDetailsWithInvalidJwtFromVault"/>
                    <include name="VerifySuccessFullTxnDeleteCardWithChecksum"/>
                </methods>
            </class>
        </classes>
    </test>

</suite>