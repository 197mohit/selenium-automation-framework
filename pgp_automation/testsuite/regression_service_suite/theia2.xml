            </class>
        </classes>
    </test>

    <test name="Native Initiate Txn" parallel="methods" thread-count="2">
        <classes>
            <class name="scripts.Native.InitiateTransaction"/>
        </classes>
    </test>

    <test name="Seamless">
        <classes>
            <class name="scripts.Seamless">
                <methods>
                    <include name="PGP_288_successfulSeamlessCC"/>
                    <include name="PGP_289_successfulSeamlessDC"/>
                    <include name="PGP_293_successfulSeamlessNB"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="PGP-36056 - Seamless Prepaid Cases">
        <classes>
            <class name="scripts.Seamless">
                <methods>
                    <include name="TC001_VerifyPrepaidCardisnotshowninExtendinfo"/>
                    <include name="TC002_VerifyPrepaidCardisnotshowninExtendinfo"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="SeamlessNative">
        <classes>
            <class name="scripts.SeamlessNative">
