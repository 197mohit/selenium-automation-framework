                    <include name="PGP_359_successfulSeamlessNativeCC"/>
                    <include name="PGP_360_successfulSeamlessNativeDC"/>
                    <include name="PGP_364_successfulSeamlesNativeNB"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="Native Fetch Pay Options" parallel="methods" thread-count="3">
