            <class name="scripts.api.theia.fetchCardIdxNo.JWTTokenFetchCardIndexNoTest"/>
        </classes>
    </test>

    <test name="FPO Native cases for PGP-21772">
        <classes>
            <class name="scripts.api.theia.fetchPayOptions.FetchPayOptionsV1Test">
                <methods>
                    <include name="test priority in fpo for all paymodes for default merchant"/>
                    <include name="enhancedOrderingLoggedIn"/>
