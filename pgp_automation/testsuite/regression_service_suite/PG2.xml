<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="PG2.0 Test Cases" verbose="1" thread-count="20" parallel="tests">
    <test name="PG2.0 PPBL Test Cases">
        <classes>
            <class name="scripts.api.PPBL.PPBLPG2">
                <methods>
                    <exclude name="userNotPrsentInFF4JPPBLTxnRoutedToPPlus"/>
                    <exclude name="userPrsentMidNotPresentInFF4JPPBLTxnRoutedToPPlus"/>
                    <exclude name="validatePG2EnabledCoThenPaySuccessPPBLTxnPG2MID"/>
                    <exclude name="validatePG2EnabledCoThenPayFailPPBLTxnPG2MID"/>
                    <exclude name="validatePG2EnabledCoThenPayPendingPPBLTxnPG2MID"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="PG2.0 PostPaid Test Cases">
        <classes>
            <class name="scripts.api.PostPaid.PG2PostPaid">
                <methods>
                    <exclude name="validateUserNotPresentInFF4JPostPaidTxnRoutedToPPlus"/>
                    <exclude name="validatePG2EnabledCoThenPaySuccessPostPaidTxnPG2MID"/>
                    <exclude name="validatePG2EnabledCoThenPayFailPostPaidTxnPG2MID"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="PG2.0 UPI Test Cases">
        <classes>
            <class name="scripts.api.UPI.UPItransactionPG2">
                <methods>
                    <exclude name="userNotPrsentInFF4JUPIPushTxnRoutedToPPlus"/>
                    <exclude name="userPrsentMidNotPresentInFF4JUPIPushTxnRoutedToPPlus"/>
                    <exclude name="validatePG2EnabledCoThenPaySuccessUPIPUSHTxnPG2MID"/>
                    <exclude name="validatePG2EnabledCoThenPayFailUPIPUSHTxnPG2MID"/>
                    <exclude name="validatePG2EnabledCoThenPayPendingUPIPUSHTxnPG2MID"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="Verify PG2 Wallet Txn">
        <classes>
            <class name="scripts.api.Wallet.PG2Wallet">
                <methods>
                    <exclude name="validatePG2EnabledCoThenPayFailWalletTxnPG2MID"/>
                    <exclude name="validatePG2EnabledCoThenPaySuccessWalletTxnPG2MID"/>
                    <exclude name="validateUserNotPresentInFF4JWalletTxnRoutedToPPlus"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="Verify PG2 Debit Card Txn">
        <classes>
            <class name="scripts.api.Debitcard.PG2Debitcard"/>
        </classes>
    </test>

    <test name="Verify PG2 Credit Card Txn">
        <classes>
            <class name="scripts.api.CC.CC_PG2">
                <methods>
                    <exclude name="validateSuccessUnsavedPplusCCTxnPG2MID"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="Verify PG2 FeeCharge Txn">
        <classes>
            <class name="scripts.api.FeeCharge.FeeChargePG2"/>
        </classes>
    </test>

    <test name="Net Banking test cases">
        <classes>
            <class name="scripts.api.NetBanking.NBPG2">
                <methods>
                    <include name="validateSuccessNBTxnPG2MID"/>
                    <include name="validatePendingNBTxnPG2MIDCloseOrderV1ThenCheckMerchantStatus"/>
                    <include name="validatePendingNBTxnPG2MIDCloseOrderV2ThenCheckMerchantStatus"/>
                   <!-- <include name="userNotPrsentInFF4JNBTxnRoutedToPPlus"/> P+ txn deprecated-->
                    <include name="midNotPrsentInFF4JButPrefEnabledNBRoutedToPG2PendingTxn"/>
                    <!--<include name="userPrsentMidNotPresentInFF4JNBTxnRoutedToPPlus"/> P+ txn deprecated-->
                    <include name="validateCOPFullTrafficPendingNBTxnPG2MID"/>
                    <include name="validateFullTrafficCOPSuccessNBTxn"/>
                    <include name="validateFullTrafficCOTPPendingNBTxn"/>
                    <include name="validateFullTrafficCOTPSuccessNBTxn"/>
                    <include name="validatePG2COThenPayFullTrafficYPPBLSuccessCheckoutJSPageTxn"/>
                    <!--<include name="validateSuccessNBTxnPG2ENABLEDPref"/> P+ txn deprecated-->
                    <include name="validateSuccessHDFCNBTxnPG2MID"/>
                    <exclude name="userNotPrsentInFF4JNBTxnRoutedToPPlus"/>
                    <exclude name="userPrsentMidNotPresentInFF4JNBTxnRoutedToPPlus"/>
                    <exclude name="validateSuccessNBTxnPG2ENABLEDPref"/>
                    <include name="nbEnhancedFlow"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="Verify PG2 UPI Collect Txns">
        <classes>
            <class name="scripts.api.UPI.UPICollectTransactionPG2">
                <methods>
                    <include name="validateSuccessPG2UPICollectTxn_PG2MID_FullTrafficenabled"/>
                    <include name="validateFailPG2UPICollectTxn_PG2MID_FullTrafficenabled"/>
                    <include name="validateSuccessPG2UPICollectTxn_PG2MID_PG2Enabled"/>
                    <include name="validateFailPG2UPICollectTxn_PG2MID_PG2Enabled"/>
                    <include name="validateSuccessPG2UPICollectTxn_PG2MID_PaymentAdapter"/>
                    <include name="validateFailPG2UPICollectTxn_PG2MID_PaymentAdapter"/>
                    <include name="validatePartialAsyncRefund_UPICollectTxnPG2MID_FullTrafficEnabled"/>
                    <include name="validateFullAsyncRefund_UPICollectTxnPG2MID_FullTrafficEnabled"/>
                    <include name="upiCollectEnhancedFlow"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="PG2 UPI Collect txn using checkoutJS">
        <parameter name="theme" value="checkoutjs_web_revamp"/>
        <classes>
            <class name="scripts.api.UPI.UPICollectTransactionPG2">
                <methods>
                    <include name="validateSuccessPG2UPICollectTxn_COTP_PG2MID_FullTrafficenabled"/>
                    <include name="validateFailPG2UPICollectTxn_COTP_PG2MID_FullTrafficenabled"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="Native">
        <classes>
            <class name="scripts.DccPg2">
                <methods>
                    <include name="successfulTransactionForMdrCC"/>
                    <include name="unsuccessfulTransactionForMdrCC"/>
                    <include name="successfulTransactionForPcfCC"/>
                    <include name="successfulTransactionWithINRForPcfDC"/>
                    <include name="dccPg2MerchantStatusValidation"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="Enhanced">
        <parameter name="theme" value="enhancedweb_revamp"></parameter>
        <classes>
            <class name="scripts.DccPg2">
                <methods>
                    <include name="pg2DccEnhancedFlow"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="CheckoutJS">
        <parameter name="theme" value="checkoutjs_web_revamp"></parameter>
        <classes>
            <class name="scripts.DccPg2">
                <methods>
                    <include name="pg2DccChekoutJsFlow"/>
                </methods>
            </class>
        </classes>
    </test>

</suite>

