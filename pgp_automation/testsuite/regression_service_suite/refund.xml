<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Refund Suite" verbose="1" thread-count="12" parallel="tests">

    <test name="PGP-14676 Auto Refund on enhanced web">
        <parameter name="theme" value="enhancedweb_revamp"/>
        <classes>
            <class name="scripts.Sprint28.AutoRefund">
                <methods>
                    <!-- Excluding Zero Pass Percentage TCs -->
                    <exclude name="fundBackPaytmCCPeon"/>
                    <exclude name="fundBackUPICollectPeon"/>
                    <exclude name="fundBackBalance"/>
                    <exclude name="fundBackHybrid"/>
                    <exclude name="revokeCCPeon"/>
                    <exclude name="revokeDCPeon"/>
                    <exclude name="revokeNBPeon"/>
                    <exclude name="revokePaytmCCPeon"/>
                    <exclude name="revokePPBLPeon"/>
                    <exclude name="revokeUPICollectPeon"/>
                    <exclude name="refundUPIIntentPeon"/>
                    <exclude name="revokeCCPWPPeon"/>
                </methods>
            </class>
        </classes>
    </test>

