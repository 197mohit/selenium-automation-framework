<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Link_Service" verbose="1" thread-count="20" parallel="tests">

    <test name="PGP 16003 - Link Based Limit OTP breach only API">
        <classes>
            <class name="scripts.Sprint28.LimitOtpLinkBased">
                <methods>
                    <include name="verifyBreachNumber"/>
                    <include name="generateOTPLimit"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="PGP-31212 Link Payment 1">
        <parameter name="theme" value="enhancedweb_revamp"/>
        <classes>
            <class name="scripts.PGOnly">
                <methods>
                    <include name="ValidateSuccessfulLinkPayment"/>
                    <include name="ValidateSuccessfulNativeSTLinkPayment"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="Move Payment Links to JS Checkout">
        <parameter name="isNativePlus" value="true"/>
        <classes>
            <class name="scripts.PGOnly">
                <methods>
                    <include name="MovePaymentLinkstoJSCheckout"/>
                </methods>
            </class>
        </classes>
    </test>

