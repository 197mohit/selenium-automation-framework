    <test name="PGOnly with enhancedweb">
        <parameter name="theme" value="enhancedweb_revamp"/>
        <classes>
            <class name="scripts.PGOnly">
                <methods>
                    <include name="PGP_269_verifySaveCardThroughDCTxn"/>
                    <include name="PGP_270_verifyCCSavedCardTxn"/>
                    <include name="PGP_verifySaveCardWithoutLogin"/>
                    <include name="PGP_249_savedCardCancelOn3DPage"/>
                    <include name="validatePGOnlyRetryTxnUsingSavedCard"/>
                    <include name="savedCardInfoNotGettingSavedPGP17483"/>
                    <!-- Exclude Zero Pass Percentage
                    <include name="PGP_251_verifySavedCardListAfterLogin"/-->
                </methods>
            </class>
        </classes>
    </test>



    <test name="PGOnly with enhancedwap">
