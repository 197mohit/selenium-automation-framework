<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Merchant_Status_Suite" verbose="1" thread-count="20" parallel="tests">

    <test name="PGP-30167_emi subvention data and promo checkout data presence in merchant-status response and peon controlled by ff4j - native plus">
        <parameter name="isNativePlus" value="true"/>
        <classes>
            <class name="scripts.api.theia.emiSubvention.EmiSubventionApiTests">
                <methods>
                    <include name="AmountEMISubvention_peonON_MerchantStatusOFF"/>
                    <include name="ItemEMISubvention_peonOFF_MerchantStatusON"/>
                    <include name="ApplyPromoAndAmountEmiSubventionBothApplied_PeonON_MerchantStatusOFF_PromoOFF"/>
                    <include name="ApplyPromoAndItemEmiSubventionBothApplied_PeonON_MerchantStatusON_PromoON"/>
                    <include name="FailureTxn_ApplyPromoAndAmountEmiSubventionBothApplied_PeonON_MerchantStatusON_PromoON"/>
                </methods>
            </class>
        </classes>
    </test>


    <test name="temp-PGP21884 TC's ">
        <parameter name="theme" value="enhancedweb_revamp"/>
        <classes>
            <class name="scripts.Native.NativeMerchantStatus">
                <methods>
                    <include name="validateNewParamsInNativeTxnStatus"/>
                </methods>
            </class>
        </classes>
    </test>



</suite>