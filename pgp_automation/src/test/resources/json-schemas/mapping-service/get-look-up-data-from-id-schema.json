{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "$ref": "#/definitions/Root",
  "definitions": {
    "Root": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "integer"
        },
        "category": {
          "type": "string"
        },
        "subCategory": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "value": {
          "type": "string"
        },
        "status": {
          "type": "integer"
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "createdBy": {
          "type": [
            "integer",
            "null"
          ]
        },
        "createdDate": {
          "pattern": "^([0-9]{4}-[0-1][0-9]-[0-3][0-9] [0-2][0-9]:[0-5][0-9]:[0-5][0-9]\\.0|)$"
        },
        "modifiedBy": {
          "type": "null"
        },
        "modifiedDate": {
          "pattern": "^([0-9]{4}-[0-1][0-9]-[0-3][0-9] [0-2][0-9]:[0-5][0-9]:[0-5][0-9]\\.0|)$"
        }
      },
      "required": [
        "category",
        "createdBy",
        "createdDate",
        "description",
        "id",
        "modifiedBy",
        "modifiedDate",
        "name",
        "status",
        "subCategory",
        "value"
      ],
      "title": "Root"
    }
  }
}
