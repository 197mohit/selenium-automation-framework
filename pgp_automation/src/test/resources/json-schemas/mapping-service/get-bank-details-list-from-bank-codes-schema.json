{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "$ref": "#/definitions/Root",
  "definitions": {
    "Root": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "response": {
          "$ref": "#/definitions/Response"
        },
        "bankIds": {
          "type": "string",
          "pattern": "^[0-9]+$"
        },
        "bankMasterDetailsList": {
          "type": "array",
          "minItems": 0,
          "items": {
            "$ref": "#/definitions/BankMasterDetailsList"
          }
        },
        "notFound": {
          "type": "array",
          "minItems": 0,
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "bankIds",
        "bankMasterDetailsList",
        "notFound",
        "response"
      ],
      "title": "Root"
    },
    "BankMasterDetailsList": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "bankId": {
          "type": "integer"
        },
        "bankName": {
          "type": "string"
        },
        "bankCode": {
          "type": "string"
        },
        "bankDisplayName": {
          "type": "string"
        },
        "bankKey": {
          "type": [
            "string",
            "null"
          ]
        },
        "alipayBankCode": {
          "type": "string"
        },
        "bankWebLogo": {
          "type": [
            "string",
            "null"
          ]
        },
        "bankWapLogo": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "type": "boolean"
        },
        "bankMandate": {
          "type": [
            "string",
            "null"
          ]
        },
        "standardBankCode": {
          "type": [
            "string",
            "null"
          ]
        },
        "mandateNetBanking": {
          "type": "boolean"
        },
        "mandateDebitCard": {
          "type": "boolean"
        },
        "payMode": {
          "type": [
            "string",
            "null"
          ]
        },
        "displayOrder": {
          "type": [
            "string",
            "null"
          ]
        },
        "extendedInfo": {
          "type": [
            "string",
            "null"
          ]
        },
        "extIfscCode": {
          "type": [
            "string",
            "null"
          ]
        },
        "bankShortName": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "alipayBankCode",
        "bankCode",
        "bankDisplayName",
        "bankId",
        "bankKey",
        "bankMandate",
        "bankName",
        "bankWapLogo",
        "bankWebLogo",
        "displayOrder",
        "mandateDebitCard",
        "mandateNetBanking",
        "payMode",
        "standardBankCode",
        "status",
        "extIfscCode",
        "bankShortName"
      ],
      "title": "BankMasterDetailsList"
    },
    "Response": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "resultCode": {
          "type": "string",
          "enum": [
            "00000"
          ]
        },
        "resultStatus": {
          "type": "string",
          "enum": [
            "S"
          ]
        },
        "messaage": {
          "type": "string",
          "enum": [
            "Success"
          ]
        }
      },
      "required": [
        "messaage",
        "resultCode",
        "resultStatus"
      ],
      "title": "Response"
    }
  }
}
