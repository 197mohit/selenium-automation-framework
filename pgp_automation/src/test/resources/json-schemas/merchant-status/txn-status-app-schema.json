{
  "$schema": "http://json-schema.org/draft-07/schema",
  "type": "object",
  "required": [
    "head",
    "body"
  ],
  "additionalProperties": false,
  "properties": {
    "head": {
      "type": "object",
      "required": [
        "mid",
        "responseTimestamp"
      ],
      "additionalProperties": false,
      "properties": {
        "mid": {
          "type": "string"
        },
        "responseTimestamp": {
          "type": "string"
        }
      }
    },
    "body": {
      "type": "object",
      "required": [
        "TXNID",
        "BANKTXNID",
        "ORDERID",
        "TXNAMOUNT",
        "STATUS",
        "TXNTYPE",
        "RESPCODE",
        "RESPMSG",
        "MID",
        "REFUNDAMT",
        "TXNDATE",
        "resultInfo"
      ],
      "additionalProperties": false,
      "properties": {
        "TXNID": {
          "pattern": "^[0-9]*$"
        },
        "BANKTXNID": {
          "pattern": "^[0-9]*$"
        },
        "ORDERID": {
          "type": "string",
          "minLength": 0
        },
        "TXNAMOUNT": {
          "pattern": "^([0-9]+\\.[0-9]{2}|)$"
        },
        "STATUS": {
          "enum": [
            "",
            "TXN_SUCCESS",
            "TXN_FAILURE",
            "PENDING"
          ]
        },
        "TXNTYPE": {
          "enum": [
            "",
            "SALE"
          ]
        },
        "GATEWAYNAME": {
          "enum": [
            "",
            "WALLET"
          ]
        },
        "RESPCODE": {
          "enum": [
            "",
            "01",
            "235",
            "402"
          ]
        },
        "RESPMSG": {
          "enum": [
            "",
            "Txn Success",
            "Wallet balance Insufficient",
            "Looks like the payment is not complete. Please wait while we confirm the status with your bank."
          ]
        },
        "BANKNAME": {
          "enum": [
            "",
            "WALLET"
          ]
        },
        "MID": {
          "enum": [
            ""
          ]
        },
        "PAYMENTMODE": {
          "enum": [
            "",
            "PPI"
          ]
        },
        "REFUNDAMT": {
          "pattern": "^([0-9]+\\.[0-9]{1,2}|)$"
        },
        "TXNDATE": {
          "pattern": "^([0-9]{4}-[0-1][0-9]-[0-3][0-9] [0-2][0-9]:[0-5][0-9]:[0-5][0-9]\\.0|)$"
        },
        "resultInfo": {
          "type": "object",
          "required": [
            "resultStatus",
            "resultCodeId",
            "resultCode",
            "resultMsg"
          ],
          "additionalProperties": false,
          "properties": {
            "resultStatus": {
              "enum": [
                "S",
                "F"
              ]
            },
            "resultCodeId": {
              "enum": [
                "00023424",
                "234234234"
              ]
            },
            "resultCode": {
              "enum": [
                "Success",
                "failure"
              ]
            },
            "resultMsg": {
              "enum": [
                "Success",
                "Order Id is invalid"
              ]
            }
          }
        }
      }
    }
  }
}