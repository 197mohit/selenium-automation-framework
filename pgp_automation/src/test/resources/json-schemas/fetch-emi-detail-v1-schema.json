{
  "$schema": "http://json-schema.org/draft-07/schema",
  "definitions": {
    "money": {
      "type": "object",
      "required": [
        "currency",
        "value"
      ],
      "properties": {
        "currency": {
          "enum": [
            "INR"
          ]
        },
        "value": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]{2}$"
        }
      },
      "additionalProperties": false
    }
  },
  "type": "object",
  "required": [
    "head",
    "body"
  ],
  "properties": {
    "head": {
      "type": "object",
      "required": [
        "requestId",
        "responseTimestamp",
        "version"
      ],
      "properties": {
        "requestId": {
          "type": "null"
        },
        "responseTimestamp": {
          "type": "string",
          "pattern": "[0-9]{13,}"
        },
        "version": {
          "enum": [
            "v1"
          ]
        }
      },
      "additionalProperties": false
    },
    "body": {
      "type": "object",
      "required": [
        "extraParamsMap",
        "resultInfo",
        "emiDetail"
      ],
      "properties": {
        "extraParamsMap": {
          "type": "null"
        },
        "resultInfo": {
          "type": "object",
          "required": [
            "resultStatus",
            "resultCode",
            "resultMsg"
          ],
          "properties": {
            "resultStatus": {
              "enum": [
                "S",
                "F",
                "U"
              ]
            },
            "resultCode": {
              "type": "string"
            },
            "resultMsg": {
              "type": "string"
            },
            "resultMsgRegional": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "emiDetail": {
          "type": [
            "object",
            "null"
          ],
          "required": [
            "isDisabled",
            "hasLowSuccess",
            "emiChannelInfos",
            "isHybridDisabled"
          ],
          "properties": {
            "isDisabled": {
              "type": "null"
            },
            "hasLowSuccess": {
              "type": "null"
            },
            "emiChannelInfos": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "planId",
                  "interestRate",
                  "ofMonths",
                  "minAmount",
                  "maxAmount",
                  "emiAmount",
                  "totalAmount"
                ],
                "properties": {
                  "planId": {
                    "type": "string",
                    "pattern": "^[A-Z]+\\|[0-9]+$"
                  },
                  "interestRate": {
                    "type": "string"
                  },
                  "ofMonths": {
                    "type": "string",
                    "pattern": "^[1-9][0-9]*$"
                  },
                  "minAmount": {
                    "$ref": "#/definitions/money"
                  },
                  "maxAmount": {
                    "$ref": "#/definitions/money"
                  },
                  "emiAmount": {
                    "anyOf": [
                      {
                        "$ref": "#/definitions/money"
                      },
                      {
                        "type": "null"
                      }
                    ]
                  },
                  "totalAmount": {
                    "anyOf": [
                      {
                        "$ref": "#/definitions/money"
                      },
                      {
                        "type": "null"
                      }
                    ]
                  }
                },
                "additionalProperties": false
              }
            },
            "isHybridDisabled": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}