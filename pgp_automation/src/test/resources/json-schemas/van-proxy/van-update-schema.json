{
  "$schema": "http://json-schema.org/draft-04/schema",
  "type": "object",
  "required": [
    "head",
    "body"
  ],
  "properties": {
    "head": {
      "type": "object",
      "required": [
        "responseTimestamp"
      ],
      "properties": {
        "signature": {
          "type": [
            "string",
            "null"
          ]
        },
        "clientId": {
          "type": "string"
        },
        "responseTimestamp": {
          "type": "string"
        },
        "signature": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "body": {
      "type": "object",
      "required": [
        "resultInfo"
      ],
      "properties": {
        "resultInfo": {
          "type": "object",
          "required": [
            "resultStatus",
            "resultCode",
            "resultMsg"
          ],
          "properties": {
            "resultStatus": {
              "enum": [
                "S",
                "F",
                "U"
              ]
            },
            "resultCode": {
              "type": "string",
              "minLength": 1
            },
            "resultMsg": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "vanInfo": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "responseStatus"
            ],
            "properties": {
              "van": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "vanStatus": {
                "enum": [
                  "ACTIVE",
                  "INACTIVE"
                ]
              },
              "responseStatus": {
                "enum": [
                  "SUCCESS",
                  "FAILURE"
                ]
              },
              "errorCode": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "errorMessage": {
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}