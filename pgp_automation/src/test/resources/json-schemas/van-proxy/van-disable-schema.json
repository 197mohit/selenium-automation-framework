{
  "$schema": "http://json-schema.org/draft-04/schema",
  "type": "object",
  "required": [
    "body"
  ],
  "properties": {
    "head": {
      "type": "object",
      "properties": {
        "responseTimestamp": {
          "type": ["string", "null"]
        },
        "clientId": {
          "type": ["string", "null"]
        },
        "signature": {
          "type": ["string","null"]
        }
      },
      "additionalProperties": false
    },
    "body": {
      "type": "object",
      "required": [
        "resultInfo"
      ],
      "properties": {
        "resultInfo": {
          "type": "object",
          "required": [
            "resultStatus",
            "resultCode",
            "resultMsg"
          ],
          "properties": {
            "resultStatus": {
              "enum": [ "S",
                "F",
                "U"]
            },
            "resultCode": {
              "type": "string",
              "minLength": 1
            },
            "resultMsg": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }

  },
  "additionalProperties": false
}