## Test Case Writing Standards

### Test Method Structure
```java
// CORRECT PGOnly E2E CC payment pattern — copy this exactly
@Feature("PGP-XXXX")
@Test(groups = {"smoke", "regression", "pgp-xxxx"}, description = "Clear business-focused description.")
@Parameters({"theme"})
public void testSomething(@Optional("enhancedweb_revamp") String theme) throws Exception {
    SoftAssertions softly = new SoftAssertions();

    // Arrange
    Constants.MerchantType merchant = Constants.MerchantType.PGOnly;
    OrderDTO orderDTO = new OrderFactory.PGOnly(merchant, theme)
            .setTXN_AMOUNT("1.00")
            .build();

    // Act
    checkoutPage.createOrder(orderDTO);
    CashierPage cashierPage = CashierPageFactory.getCashierPage(theme);
    cashierPage.payBy(Constants.PayMode.CC);
    responsePage.waitUntilLoads();

    // Internal TxnStatus confirmation — fluent chain (preferred)
    TxnStatus txnStatus = new TxnStatus(orderDTO.getMID(), orderDTO.getORDER_ID());
    txnStatus.executeUntilNotPending();
    txnStatus.validateStatus("TXN_SUCCESS")
             .validateRespCode(Constants.ResponseCode.TXN_SUCCESS.getRespCode())
             .validateOrderid(orderDTO.getORDER_ID())
             .AssertAll();
    // OR: access via getters after execute
    // softly.assertThat(txnStatus.getResponse().getRESPCODE()).isEqualTo("01");
    // NOTE: for raw jsonPath access, use Pattern C — store execute() result as Response and call jsonPath() on it

    // External merchant-status assertion via GetPaymentStatus
    // For PGOnly: use 2-param constructor — aggrMid is null in PGOnly, do NOT use 4-param version
    GetPaymentStatusDTO getPaymentStatusDTO = new GetPaymentStatusDTO.Builder(
            orderDTO.getORDER_ID(), merchant)
            .build();
    Response gpsResponse = new GetPaymentStatus(getPaymentStatusDTO).execute();
    JsonPath jsonPath = gpsResponse.jsonPath();
    softly.assertThat(jsonPath.getString("body.resultInfo.resultStatus"))
          .as("resultStatus").isEqualToIgnoringCase("TXN_SUCCESS");
    softly.assertThat(jsonPath.getString("body.resultInfo.resultCode"))
          .as("resultCode").isEqualTo(Constants.ResponseCode.TXN_SUCCESS.getRespCode());
    softly.assertThat(jsonPath.getString("body.orderId"))
          .as("orderId").isEqualToIgnoringCase(orderDTO.getORDER_ID());
    softly.assertThat(jsonPath.getString("body.mid"))
          .as("mid").isEqualToIgnoringCase(orderDTO.getMID());

    softly.assertAll();
}
```

