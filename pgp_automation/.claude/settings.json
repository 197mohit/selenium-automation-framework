{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 1"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(foundry:*)",
      "Bash(git:*)",
      "Bash(make:*)",
      "Bash(mvn:*)",
      "Edit",
      "Read",
      "Write"
    ]
  },
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "OTEL_METRICS_EXPORTER": "otlp",
    "OTEL_LOGS_EXPORTER": "otlp",
    "OTEL_EXPORTER_OTLP_PROTOCOL": "http/protobuf",
    "OTEL_EXPORTER_OTLP_ENDPOINT": "https://foundry.mypaytm.com/otel",
    "OTEL_LOG_USER_PROMPTS": "1",
    "OTEL_LOG_TOOL_DETAILS": "1"
  }
}
